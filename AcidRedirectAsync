local SWEEP_ANGLES = { 0 }
do
	local deg = CONFIG.SafePathAngleStep

	while deg <= CONFIG.SafePathMaxAngle do
		table.insert(SWEEP_ANGLES, deg)

		if deg < CONFIG.SafePathMaxAngle then
			table.insert(SWEEP_ANGLES, -deg)
		end

		deg += CONFIG.SafePathAngleStep
	end
end

local notifyTimes = {}

local function notifyHazard(message, duration)
	if not NotifyCallback then return end

	pcall(function()
		NotifyCallback("Acid-Redirect", message, duration or 2.5)
	end)
end

local function notifyHazardThrottled(key, message, duration)
	if CONFIG.EnableNotifications == false then return end

	local now = os.clock()
	local last = notifyTimes[key]

	if last and now - last < CONFIG.NotificationCooldown then
		return
	end

	notifyTimes[key] = now
	notifyHazard(message, duration)
end

