if typeof(loaderOptions) ~= "table" then loaderOptions = {} end

local NotifyCallback = (typeof(loaderOptions.Notify) == "function") and loaderOptions.Notify or nil
local ExternalPredictPlayerLanding = (typeof(loaderOptions.PredictPlayerLanding) == "function") and loaderOptions.PredictPlayerLanding or nil

