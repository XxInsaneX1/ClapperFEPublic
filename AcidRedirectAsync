local function clearArray(array)
	for index = #array, 1, -1 do
		array[index] = nil
	end
end

local function getArcFolder()
	local folder = Workspace:FindFirstChild(CONFIG.ArcFolderName)

	if not folder then
		folder        = Instance.new("Folder")
		folder.Name   = CONFIG.ArcFolderName
		folder.Parent = Workspace
	end

	return folder
end

local function clearTrajectoryArc()
	local folder = Workspace:FindFirstChild(CONFIG.ArcFolderName)
	if folder then
		folder:ClearAllChildren()
	end
end

local function makeArcPart(name, size, color, transparency)
	local part = Instance.new("Part")
	part.Name          = name
	part.Anchored      = true
	part.CanCollide    = false
	part.CanTouch      = false
	part.CanQuery      = false
	part.CastShadow    = false
	part.Material      = CONFIG.ArcMaterial
	part.Color         = color
	part.Transparency  = transparency
	part.Size          = size
	part.TopSurface    = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function getCylinderCFrameBetween(a, b)
	local midpoint  = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up    = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right      = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawTrajectoryArc(prediction, danger)
	if not CONFIG.ShowTrajectoryArc then return end

	clearTrajectoryArc()

	if not prediction
		or typeof(prediction.Trajectory) ~= "table"
		or #prediction.Trajectory <= 0 then
		return
	end

	local trajectory = prediction.Trajectory
	local folder     = getArcFolder()
	local lineColor  = danger and CONFIG.ArcDangerColor or CONFIG.ArcSafeColor
	local stride     = math.max(CONFIG.ArcVisualStride, 1)

	for index = 1, #trajectory - 1, stride do
		local a = trajectory[index]
		local b = trajectory[math.min(index + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local segment = makeArcPart(
					"PathLine",
					Vector3.new(CONFIG.ArcThickness, distance, CONFIG.ArcThickness),
					lineColor,
					CONFIG.ArcTransparency
				)

				segment.Shape  = Enum.PartType.Cylinder
				segment.CFrame = getCylinderCFrameBetween(a, b)
				segment.Parent = folder
			end
		end
	end

	local markerPosition = prediction.LandPosition
		or prediction.RootPosition
		or trajectory[#trajectory]

	if danger and typeof(danger.Position) == "Vector3" then
		markerPosition = danger.Position
	end

	if typeof(markerPosition) == "Vector3" then
		local marker = makeArcPart(
			"EndMarker",
			Vector3.new(
				CONFIG.ArcLandingMarkerSize,
				CONFIG.ArcLandingMarkerSize,
				CONFIG.ArcLandingMarkerSize
			),
			CONFIG.ArcEndMarkerColor,
			0.02
		)

		marker.Shape  = Enum.PartType.Ball
		marker.CFrame = CFrame.new(markerPosition)
		marker.Parent = folder
	end
end

local function rebuildAcidParts()
	clearArray(acidParts)

	for part in pairs(acidPartSet) do
		acidPartSet[part] = nil
	end

	if not acidPitFolder then return end

	for _, instance in ipairs(acidPitFolder:GetDescendants()) do
		if instance:IsA("BasePart") then
			table.insert(acidParts, instance)
			acidPartSet[instance] = true
		end
	end
end

local function textHasDangerKeyword(text)
	if typeof(text) ~= "string" then return false end

	local lowered = string.lower(text)

	for _, keyword in ipairs(CONFIG.DangerKeywords) do
		if string.find(lowered, string.lower(keyword), 1, true) then
			return true
		end
	end

	return false
end

local function attributesMentionDanger(instance)
	if not instance or not instance.GetAttributes then return false end

	local ok, attributes = pcall(function()
		return instance:GetAttributes()
	end)

	if not ok or typeof(attributes) ~= "table" then return false end

	for key, value in pairs(attributes) do
		if textHasDangerKeyword(tostring(key)) or textHasDangerKeyword(tostring(value)) then
			return true
		end
	end

	return false
end

local function descendantsMentionDanger(instance)
	if not instance then return false end

	local scanned = 0

	for _, descendant in ipairs(instance:GetDescendants()) do
		scanned += 1

		if scanned > CONFIG.DangerDescendantScanLimit then break end

		if textHasDangerKeyword(descendant.Name) or attributesMentionDanger(descendant) then
			return true
		end

		if descendant:IsA("ParticleEmitter")
			or descendant:IsA("Beam")
			or descendant:IsA("Trail")
			or descendant:IsA("Fire")
			or descendant:IsA("Smoke")
			or descendant:IsA("Sparkles")
			or descendant:IsA("PointLight")
			or descendant:IsA("SurfaceLight")
			or descendant:IsA("SpotLight") then

			if textHasDangerKeyword(descendant.Name) then
				return true
			end

			local parent = descendant.Parent

			if parent and textHasDangerKeyword(parent.Name) then
				return true
			end
		end
	end

	return false
end

local function ancestryMentionsDanger(instance)
	local current = instance
	local depth   = 0

	while current and current ~= Workspace and depth < 8 do
		depth += 1

		if textHasDangerKeyword(current.Name) or attributesMentionDanger(current) then
			return true
		end

		current = current.Parent
	end

	return false
end

local function isDangerousInstance(instance)
	if not instance then return false end

	if acidPitFolder and instance:IsDescendantOf(acidPitFolder) then
		return true
	end

	if not CONFIG.EnableKeywordHazardDetection then return false end

	if ancestryMentionsDanger(instance) then return true end
	if descendantsMentionDanger(instance) then return true end

	return false
end

local function getRootPart(model)
	if not model then return nil end

	return model:FindFirstChild("HumanoidRootPart")
		or model:FindFirstChild("Torso")
		or model:FindFirstChild("UpperTorso")
end

local function isRagdolled()
	if not humanoid then return false end

	local state = humanoid:GetState()

	return state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
end

local function updateRaycastParams()
	local exclude = if character then { character } else {}

	raycastParams.FilterDescendantsInstances            = exclude
	broadHazardOverlapParams.FilterDescendantsInstances = exclude
end

local function setupCharacter(nextCharacter)
	character = nextCharacter
	humanoid  = nextCharacter and nextCharacter:FindFirstChildOfClass("Humanoid") or nil
	rootPart  = getRootPart(nextCharacter)
	updateRaycastParams()
end

local function pointInsidePartBounds(point, part, padding)
	local localPoint = part.CFrame:PointToObjectSpace(point)
	local halfSize   = part.Size * 0.5

	return math.abs(localPoint.X) <= halfSize.X + padding
		and math.abs(localPoint.Y) <= halfSize.Y + padding
		and math.abs(localPoint.Z) <= halfSize.Z + padding
end

local function getDangerNearPoint(point, radius)
	if acidPitFolder and overlapSupported then
		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, radius, acidOverlapParams)
		end)

		if ok then
			for _, part in ipairs(parts) do
				if isDangerousInstance(part) then
					return part
				end
			end
		else
			overlapSupported = false
		end
	end

	for _, part in ipairs(acidParts) do
		if part.Parent and pointInsidePartBounds(point, part, radius) then
			return part
		end
	end

	if CONFIG.EnableBroadHazardScan and CONFIG.EnableKeywordHazardDetection then
		local broadRadius = math.max(radius, CONFIG.BroadHazardScanRadius)

		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, broadRadius, broadHazardOverlapParams)
		end)

		if ok then
			for _, part in ipairs(parts) do
				if part:IsA("BasePart") and isDangerousInstance(part) then
					return part
				end
			end
		end
	end

	return nil
end

local function getNearestAcidDistance(position)
	local nearest = math.huge

	for _, part in ipairs(acidParts) do
		if part.Parent then
			local localPoint = part.CFrame:PointToObjectSpace(position)
			local halfSize   = part.Size * 0.5

			local dx = math.max(math.abs(localPoint.X) - halfSize.X, 0)
			local dy = math.max(math.abs(localPoint.Y) - halfSize.Y, 0)
			local dz = math.max(math.abs(localPoint.Z) - halfSize.Z, 0)

			local distance = Vector3.new(dx, dy, dz).Magnitude

			if distance < nearest then
				nearest = distance
			end
		end
	end

	-- FIX: was returning 0 when acidParts is empty (fallback folder case).
	-- Returning 0 made nearestAcidDistance always <= ActivationDistance,
	-- causing the script to think the player was always at the acid pit and
	-- run prediction + redirect logic everywhere in the map.
	-- Now returns math.huge when no parts are found, which correctly causes
	-- shouldPredict() to early-return false until real acid parts load in.
	return nearest
end

local function getHorizontal(vector)
	return Vector3.new(vector.X, 0, vector.Z)
end

local function getMass()
	if rootPart and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end
	return 70
end

local function getDragAcceleration(velocity)
	local speed = velocity.Magnitude
	if speed <= 0.001 then return Vector3.zero end

	local dragMagnitude = 0.5
		* CONFIG.AirDensity
		* CONFIG.DragCoefficient
		* CONFIG.CrossSectionArea
		* speed * speed

	return -velocity.Unit * (dragMagnitude / getMass())
end

local function getMagnusAcceleration(velocity, angularVelocity)
	if velocity.Magnitude <= 0.001
		or angularVelocity.Magnitude <= 0.001
		or CONFIG.MagnusCoefficient <= 0 then
		return Vector3.zero
	end

	local magnus = angularVelocity:Cross(velocity) * CONFIG.MagnusCoefficient

	if magnus.Magnitude > CONFIG.MaxMagnusAcceleration then
		magnus = magnus.Unit * CONFIG.MaxMagnusAcceleration
	end

	return magnus
end

local function predictTrajectoryInternal()
	if not rootPart or not rootPart.Parent then return nil end

	local position        = rootPart.Position
	local velocity        = rootPart.AssemblyLinearVelocity
	local angularVelocity = rootPart.AssemblyAngularVelocity
	local gravity         = Vector3.new(0, -Workspace.Gravity, 0)
	local trajectory      = { position }

	local elapsed   = 0
	local stepIndex = 0

	while elapsed < CONFIG.PredictionMaxTime do
		if not rootPart.Parent then break end

		stepIndex += 1

		local step         = math.min(CONFIG.PredictionTimeStep, CONFIG.PredictionMaxTime - elapsed)
		local acceleration = gravity
			+ getDragAcceleration(velocity)
			+ getMagnusAcceleration(velocity, angularVelocity)
		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position

		if displacement.Magnitude > 0.001 then
			local hitResult
			local castOk, castResult = pcall(function()
				return Workspace:Spherecast(position, CONFIG.CharacterRadius, displacement, raycastParams)
			end)

			if castOk then
				hitResult = castResult
			else
				hitResult = Workspace:Raycast(position, displacement, raycastParams)
			end

			if hitResult then
				local alpha        = math.clamp(hitResult.Distance / displacement.Magnitude, 0, 1)
				local rootPosition = position:Lerp(nextPosition, alpha)

				table.insert(trajectory, rootPosition)

				return {
					Trajectory   = trajectory,
					HitResult    = hitResult,
					HitPart      = hitResult.Instance,
					LandPosition = hitResult.Position,
					RootPosition = rootPosition,
					LandNormal   = hitResult.Normal,
					Time         = elapsed + step * alpha,
					Velocity     = velocity:Lerp(nextVelocity, alpha),
					Source       = "Internal",
				}
			end
		end

		if stepIndex % CONFIG.TrajectorySampleStride == 0 then
			table.insert(trajectory, nextPosition)

			local dangerPart = getDangerNearPoint(nextPosition, CONFIG.TrajectoryDangerRadius)

			if dangerPart then
				return {
					Trajectory     = trajectory,
					HitResult      = nil,
					HitPart        = dangerPart,
					LandPosition   = nextPosition,
					RootPosition   = nextPosition,
					Time           = elapsed + step,
					Velocity       = nextVelocity,
					NearDangerPart = dangerPart,
					Source         = "Internal",
				}
			end
		end

		position = nextPosition
		velocity = nextVelocity
		elapsed += step
	end

	return {
		Trajectory   = trajectory,
		HitResult    = nil,
		HitPart      = nil,
		LandPosition = position,
		RootPosition = position,
		Time         = CONFIG.PredictionMaxTime,
		Velocity     = velocity,
		Source       = "Internal",
	}
end

local function predictTrajectoryExternal()
	if not ExternalPredictPlayerLanding then return nil end

	local ok, trajectory, hitPart, hitResult, prediction = pcall(
		ExternalPredictPlayerLanding,
		LocalPlayer,
		{
			MaxTime               = CONFIG.PredictionMaxTime,
			TimeStep              = CONFIG.PredictionTimeStep,
			Gravity               = Workspace.Gravity,
			AirDensity            = CONFIG.AirDensity,
			DragCoefficient       = CONFIG.DragCoefficient,
			CrossSectionArea      = CONFIG.CrossSectionArea,
			MagnusCoefficient     = CONFIG.MagnusCoefficient,
			MaxMagnusAcceleration = CONFIG.MaxMagnusAcceleration,
			CastMode              = "Sphere",
			CastRadius            = CONFIG.CharacterRadius,
			CastPadding           = 0.05,
			IgnoreWater           = true,
			DrawArc               = false,
		}
	)

	if not ok then
		Controller.LastError = tostring(trajectory)
		return nil
	end

	if typeof(prediction) ~= "table" then return nil end

	prediction.Trajectory = prediction.Trajectory or trajectory or {}
	prediction.HitPart    = prediction.HitPart    or hitPart
	prediction.HitResult  = prediction.HitResult  or hitResult
	prediction.Source     = "External"

	return prediction
end

local function predictTrajectory()
	local externalPrediction = predictTrajectoryExternal()
	if externalPrediction then return externalPrediction end
	return predictTrajectoryInternal()
end

local function getSurfaceVelocity(velocity, normal)
	return velocity - normal * velocity:Dot(normal)
end

local function getSurfaceFriction(part)
	if not part or not part:IsA("BasePart") then
		return CONFIG.DefaultSurfaceFriction
	end

	local properties = part.CurrentPhysicalProperties
	local friction   = properties and properties.Friction or CONFIG.DefaultSurfaceFriction

	if typeof(friction) ~= "number" or friction <= 0 then
		return CONFIG.DefaultSurfaceFriction
	end

	return friction
end

local function getGroundHit(position)
	local origin       = position + Vector3.new(0, CONFIG.SlideProbeHeight * 0.5, 0)
	local displacement = Vector3.new(0, -CONFIG.SlideProbeHeight, 0)

	local ok, result = pcall(function()
		return Workspace:Spherecast(origin, CONFIG.SlideProbeRadius, displacement, raycastParams)
	end)

	if ok then return result end
	return Workspace:Raycast(origin, displacement, raycastParams)
end

local function simulateSlideDanger(prediction)
	if not CONFIG.EnableSlidePrediction then return nil end
	if not prediction then return nil end

	local hitResult = prediction.HitResult
	local groundHit = hitResult

	if not groundHit then
		groundHit = getGroundHit(
			prediction.RootPosition or prediction.LandPosition or rootPart.Position
		)
	end

	if not groundHit then return nil end

	if isDangerousInstance(groundHit.Instance) then
		return {
			Kind       = "SlideGround",
			Part       = groundHit.Instance,
			Position   = groundHit.Position,
			Prediction = prediction,
		}
	end

	local normal        = groundHit.Normal
	local position      = prediction.RootPosition or prediction.LandPosition or groundHit.Position
	local velocity      = prediction.Velocity or rootPart.AssemblyLinearVelocity
	local slideVelocity = getSurfaceVelocity(velocity, normal)
	local ragdoll       = isRagdolled()
	local elapsed       = 0

	if ragdoll and not CONFIG.EnableRagdollSlidePrediction then return nil end
	if not ragdoll and not CONFIG.EnableStandingSlidePrediction then return nil end

	if not ragdoll then
		slideVelocity *= CONFIG.StandingSlideVelocityMultiplier
	end

	if normal.Y <= 0.05 then return nil end

	while elapsed < CONFIG.SlideLookahead do
		local step               = math.min(CONFIG.SlideTimeStep, CONFIG.SlideLookahead - elapsed)
		local gravity            = Vector3.new(0, -Workspace.Gravity, 0)
		local slopeAcceleration  = gravity - normal * gravity:Dot(normal)
		local normalAcceleration = math.max(-gravity:Dot(normal), 0)
		local surfaceFriction    = getSurfaceFriction(groundHit.Instance)
		local frictionMultiplier = if ragdoll
			then CONFIG.RagdollFrictionMultiplier
			else CONFIG.StandingFrictionMultiplier
		local kineticFriction       = surfaceFriction * frictionMultiplier
		local staticFriction        = kineticFriction * CONFIG.StaticFrictionMultiplier
		local minRequiredSlideSpeed = ragdoll
			and CONFIG.MinSlideSpeed
			or CONFIG.MinStandingSlideSpeed

		if slideVelocity.Magnitude < minRequiredSlideSpeed
			and slopeAcceleration.Magnitude <= staticFriction * normalAcceleration then
			return nil
		end

		slideVelocity += slopeAcceleration * step

		if slideVelocity.Magnitude > 0.001 then
			local frictionMagnitude = math.min(
				kineticFriction * normalAcceleration,
				slideVelocity.Magnitude / step
			)
			slideVelocity -= slideVelocity.Unit * frictionMagnitude * step
		end

		if slideVelocity.Magnitude > CONFIG.MaxSlideSpeed then
			slideVelocity = slideVelocity.Unit * CONFIG.MaxSlideSpeed
		end

		if slideVelocity.Magnitude < 0.25
			and slopeAcceleration.Magnitude < CONFIG.MinSlideSpeed then
			return nil
		end

		position += slideVelocity * step

		local dangerPart = getDangerNearPoint(position, CONFIG.SlideDangerRadius)

		if dangerPart then
			return {
				Kind       = "SlideOverlap",
				Part       = dangerPart,
				Position   = position,
				Prediction = prediction,
			}
		end

		groundHit = getGroundHit(position + normal * CONFIG.SlideSurfaceOffset)

		if not groundHit then return nil end

		if isDangerousInstance(groundHit.Instance) then
			return {
				Kind       = "SlideGround",
				Part       = groundHit.Instance,
				Position   = groundHit.Position,
				Prediction = prediction,
			}
		end

		normal        = groundHit.Normal
		position      = groundHit.Position + normal * CONFIG.SlideSurfaceOffset
		slideVelocity = getSurfaceVelocity(slideVelocity, normal)
		elapsed      += step
	end

	return nil
end

local function scanTrajectoryForDanger(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then return nil end

	local trajectory = prediction.Trajectory
	local stride     = math.max(CONFIG.TrajectorySampleStride, 1)

	for index = 1, #trajectory, stride do
		local point = trajectory[index]

		if typeof(point) == "Vector3" then
			local dangerPart = getDangerNearPoint(point, CONFIG.TrajectoryDangerRadius)

			if dangerPart then
				return {
					Kind       = "AirPath",
					Part       = dangerPart,
					Position   = point,
					Prediction = prediction,
				}
			end
		end
	end

	return nil
end

local function getPredictionDanger(prediction)
	if not prediction then return nil end

	if prediction.NearDangerPart then
		return {
			Kind       = "AirPath",
			Part       = prediction.NearDangerPart,
			Position   = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	local airPathDanger = scanTrajectoryForDanger(prediction)
	if airPathDanger then return airPathDanger end

	local hitPart = prediction.HitPart

	if not hitPart and prediction.HitResult then
		hitPart = prediction.HitResult.Instance
	end

	if isDangerousInstance(hitPart) then
		return {
			Kind       = "DirectHit",
			Part       = hitPart,
			Position   = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	return simulateSlideDanger(prediction)
end

local function getClosestPointOnPartBounds(part, worldPoint)
	if not part or not part:IsA("BasePart") then return nil end

	local localPoint = part.CFrame:PointToObjectSpace(worldPoint)
	local halfSize   = part.Size * 0.5

	local clamped = Vector3.new(
		math.clamp(localPoint.X, -halfSize.X, halfSize.X),
		math.clamp(localPoint.Y, -halfSize.Y, halfSize.Y),
		math.clamp(localPoint.Z, -halfSize.Z, halfSize.Z)
	)

	return part.CFrame:PointToWorldSpace(clamped)
end

local function getEscapeDirectionFromPart(part, worldPoint)
	if not part or not part:IsA("BasePart") then return nil end

	local localPoint = part.CFrame:PointToObjectSpace(worldPoint)
	local halfSize   = part.Size * 0.5

	local closest = getClosestPointOnPartBounds(part, worldPoint)

	if closest then
		local awayFromClosest = getHorizontal(worldPoint - closest)

		if awayFromClosest.Magnitude > 0.001 then
			return awayFromClosest.Unit
		end
	end

	local distances = {
		{ Distance = math.abs(halfSize.X  - localPoint.X), Direction = Vector3.new( 1, 0, 0) },
		{ Distance = math.abs(-halfSize.X - localPoint.X), Direction = Vector3.new(-1, 0, 0) },
		{ Distance = math.abs(halfSize.Z  - localPoint.Z), Direction = Vector3.new( 0, 0,  1) },
		{ Distance = math.abs(-halfSize.Z - localPoint.Z), Direction = Vector3.new( 0, 0, -1) },
	}

	table.sort(distances, function(a, b) return a.Distance < b.Distance end)

	local worldDirection = part.CFrame:VectorToWorldSpace(distances[1].Direction)
	worldDirection       = getHorizontal(worldDirection)

	if worldDirection.Magnitude > 0.001 then
		return worldDirection.Unit
	end

	return nil
end

local function getDangerDistance(danger)
	if not rootPart or not danger then return math.huge end

	if typeof(danger.Position) == "Vector3" then
		return (rootPart.Position - danger.Position).Magnitude
	end

	if danger.Part and danger.Part:IsA("BasePart") then
		local closest = getClosestPointOnPartBounds(danger.Part, rootPart.Position)

		if closest then
			return (rootPart.Position - closest).Magnitude
		end
	end

	return math.huge
end

local function getDangerTime(danger)
	if danger and danger.Prediction and typeof(danger.Prediction.Time) == "number" then
		return danger.Prediction.Time
	end
	return math.huge
end

local function getSafeVelocity(danger)
	local currentVelocity   = rootPart.AssemblyLinearVelocity
	local currentHorizontal = getHorizontal(currentVelocity)
	local desiredDirection  = nil

	if danger.Part and danger.Part:IsA("BasePart") then
		desiredDirection = getEscapeDirectionFromPart(danger.Part, rootPart.Position)
	end

	if not desiredDirection and typeof(danger.Position) == "Vector3" then
		local awayFromDangerPoint = getHorizontal(rootPart.Position - danger.Position)

		if awayFromDangerPoint.Magnitude > 0.001 then
			desiredDirection = awayFromDangerPoint.Unit
		end
	end

	if not desiredDirection and currentHorizontal.Magnitude > 0.001 then
		desiredDirection = (-currentHorizontal).Unit
	end

	if not desiredDirection then
		local look = getHorizontal(rootPart.CFrame.LookVector)

		if look.Magnitude > 0.001 then
			desiredDirection = look.Unit
		end
	end

	if not desiredDirection then
		desiredDirection = Vector3.new(1, 0, 0)
	end

	local side = Vector3.new(-desiredDirection.Z, 0, desiredDirection.X)

	if side.Magnitude > 0.001 then
		if currentHorizontal.Magnitude > 0.001 and currentHorizontal:Dot(side) < 0 then
			side = -side
		end
		desiredDirection = (desiredDirection + side.Unit * CONFIG.SideBias).Unit
	end

	local dangerDistance = getDangerDistance(danger)
	local dangerTime     = getDangerTime(danger)
	local emergency      = dangerDistance <= CONFIG.EmergencyRedirectDistance
		or dangerTime <= CONFIG.EmergencyRedirectTime

	local minSpeed = emergency
		and CONFIG.RedirectMaxHorizontalSpeed
		or CONFIG.RedirectHorizontalSpeed

	local horizontalSpeed = math.clamp(
		math.max(currentHorizontal.Magnitude, minSpeed),
		CONFIG.RedirectHorizontalSpeed,
		CONFIG.RedirectMaxHorizontalSpeed
	)

	local lift = if string.find(danger.Kind, "Slide")
		then CONFIG.SlideRedirectLift
		else CONFIG.RedirectLift

	if emergency then
		lift = math.max(lift, CONFIG.RedirectLift + 8)
	end

	local targetY = math.max(currentVelocity.Y, lift)

	if currentVelocity.Y < -20 then
		targetY = math.max(targetY, 24)
	end

	return desiredDirection * horizontalSpeed + Vector3.new(0, targetY, 0)
end

-- Redirect only fires when:
--   (a) the player is ragdolled, OR
--   (b) horizontal speed exceeds WalkSpeed * RedirectMinSpeedMultiplier
--       plus a flat buffer (RedirectSpeedBuffer studs/s) that absorbs
--       Roblox physics jitter so normal walking never crosses the threshold.
--
-- Example with defaults (WalkSpeed 16, multiplier 1.0, buffer 2):
--   threshold = 16 * 1.0 + 2 = 18 studs/s
--   Normal walking peaks at ~16 → never fires.
--   A fling typically sends the player to 60-200 studs/s → always fires.
local function canApplyRedirect()
	if not humanoid or not rootPart or not rootPart.Parent then
		return false
	end

	if isRagdolled() then
		return true
	end

	local horizontalSpeed = getHorizontal(rootPart.AssemblyLinearVelocity).Magnitude
	local threshold       = humanoid.WalkSpeed * CONFIG.RedirectMinSpeedMultiplier
		+ CONFIG.RedirectSpeedBuffer

	return horizontalSpeed > threshold
end

local function applyRedirect(deltaTime)
	if not rootPart or not rootPart.Parent or not Controller.LastDanger then return end

	notifyHazardThrottled("attempting_redirect", "Attempting redirect to safety", 2.5)

	local danger          = Controller.LastDanger
	local currentVelocity = rootPart.AssemblyLinearVelocity
	local targetVelocity  = getSafeVelocity(danger)

	local dangerDistance = getDangerDistance(danger)
	local dangerTime     = getDangerTime(danger)
	local emergency      = dangerDistance <= CONFIG.EmergencyRedirectDistance
		or dangerTime <= CONFIG.EmergencyRedirectTime

	local alpha

	if emergency then
		alpha = CONFIG.EmergencyRedirectAlpha
	else
		alpha = 1 - math.exp(-CONFIG.RedirectResponsiveness * deltaTime)
		alpha = math.max(alpha, CONFIG.NormalRedirectMinAlpha)
	end

	local newVelocity = currentVelocity:Lerp(targetVelocity, math.clamp(alpha, 0, 1))

	rootPart.AssemblyLinearVelocity = newVelocity

	if CONFIG.ImpulseAssist and rootPart.AssemblyMass > 0 then
		local deltaVelocity = newVelocity - currentVelocity

		if deltaVelocity.Magnitude > 0.001 then
			pcall(function()
				rootPart:ApplyImpulse(
					deltaVelocity * rootPart.AssemblyMass * CONFIG.ImpulseMultiplier
				)
			end)
		end
	end
end

local function shouldPredict()
	if not rootPart or not rootPart.Parent then return false end

	-- nearestAcidDistance is now math.huge when no acid parts exist (fallback
	-- folder is empty), so this correctly short-circuits the whole function
	-- instead of falling through as if the player is at the pit.
	if nearestAcidDistance > CONFIG.ActivationDistance then return false end

	local velocity           = rootPart.AssemblyLinearVelocity
	local horizontalVelocity = getHorizontal(velocity)

	if velocity.Magnitude >= CONFIG.MinSpeedToPredict then return true end

	if CONFIG.EnableSlidePrediction
		and CONFIG.EnableStandingVelocitySlidePrediction
		and not isRagdolled()
		and horizontalVelocity.Magnitude >= CONFIG.MinStandingSlideSpeed then
		return true
	end

	if isRagdolled() then return true end

	return getDangerNearPoint(rootPart.Position, CONFIG.SlideDangerRadius) ~= nil
end

local function updateNearestAcid(deltaTime)
	nearestCheckAccumulated += deltaTime

	if nearestCheckAccumulated < 0.35 then return end

	nearestCheckAccumulated = 0

	if rootPart then
		nearestAcidDistance = getNearestAcidDistance(rootPart.Position)
	else
		nearestAcidDistance = math.huge
	end
end

local function onHeartbeat(deltaTime)
	if not Controller.Enabled then
		Controller.LastDanger     = nil
		Controller.LastPrediction = nil

		if CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end

		return
	end

	if not character or not character.Parent or not rootPart or not rootPart.Parent then
		setupCharacter(LocalPlayer.Character)
	end

	updateNearestAcid(deltaTime)
	accumulated += deltaTime

	if accumulated >= CONFIG.PredictEvery then
		accumulated = 0

		if shouldPredict() then
			local prediction = predictTrajectory()
			local danger     = getPredictionDanger(prediction)

			Controller.LastPrediction = prediction
			drawTrajectoryArc(prediction, danger)

			if danger then
				if not Controller.LastDanger then
					notifyHazardThrottled(
						"trajectory_detected",
						"Trajectory detected toward acid",
						2.5
					)
				end

				Controller.LastDanger = danger

				local dangerDistance = getDangerDistance(danger)
				local dangerTime     = getDangerTime(danger)

				if dangerDistance <= CONFIG.EmergencyRedirectDistance
					or dangerTime <= CONFIG.EmergencyRedirectTime then
					lastDangerUntil = os.clock() + math.max(CONFIG.ApplyWindow, 0.65)
				else
					lastDangerUntil = os.clock() + CONFIG.ApplyWindow
				end
			elseif os.clock() > lastDangerUntil then
				Controller.LastDanger = nil
			end
		elseif os.clock() > lastDangerUntil then
			Controller.LastDanger     = nil
			Controller.LastPrediction = nil

			if CONFIG.ClearArcWhenIdle then
				clearTrajectoryArc()
			end
		end
	end

	if Controller.LastDanger and os.clock() <= lastDangerUntil then
		if canApplyRedirect() then
			applyRedirect(deltaTime)
		end
	end
end

function Controller.Start()
	Controller.Enabled = true
	CONFIG.Enabled     = true
end

function Controller.Stop()
	Controller.Enabled        = false
	CONFIG.Enabled            = false
	Controller.LastDanger     = nil
	Controller.LastPrediction = nil
	lastDangerUntil           = 0

	if CONFIG.ClearArcWhenIdle then
		clearTrajectoryArc()
	end
end

function Controller.ShowArc()
	CONFIG.ShowTrajectoryArc = true
end

function Controller.HideArc()
	CONFIG.ShowTrajectoryArc = false
	clearTrajectoryArc()
end

function Controller.ClearArc()
	clearTrajectoryArc()
end

function Controller.SetConfig(nextConfig)
	if typeof(nextConfig) ~= "table" then return end

	for key, value in pairs(nextConfig) do
		CONFIG[key] = value
	end
end

function Controller.SetPredictor(predictor)
	if typeof(predictor) == "function" then
		ExternalPredictPlayerLanding          = predictor
		Controller.UsingExternalTrajectoryApi = true
	else
		ExternalPredictPlayerLanding          = nil
		Controller.UsingExternalTrajectoryApi = false
	end
end

function Controller.IsRedirecting()
	return Controller.LastDanger ~= nil and os.clock() <= lastDangerUntil
end

function Controller.Destroy()
	Controller.Stop()

	for _, connection in ipairs(connections) do
		pcall(function() connection:Disconnect() end)
	end

	clearArray(connections)

	if heartbeatConnection then
		pcall(function() heartbeatConnection:Disconnect() end)
		heartbeatConnection = nil
	end

	clearTrajectoryArc()

	if global.__AcidRedirectController == Controller then
		global.__AcidRedirectController = nil
	end
end

rebuildAcidParts()
setupCharacter(LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait())

table.insert(connections, LocalPlayer.CharacterAdded:Connect(setupCharacter))

if acidPitFolder then
	table.insert(connections, acidPitFolder.DescendantAdded:Connect(function(instance)
		if instance:IsA("BasePart") then
			rebuildAcidParts()
		end
	end))

	table.insert(connections, acidPitFolder.DescendantRemoving:Connect(function(instance)
		if instance:IsA("BasePart") then
			task.defer(rebuildAcidParts)
		end
	end))
end

heartbeatConnection = RunService.Heartbeat:Connect(onHeartbeat)

global.__AcidRedirectController = Controller

return Controller
