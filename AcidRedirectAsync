local function applyConfigAliases()
	local function alias(from, to)
		if CONFIG[from] ~= nil then
			CONFIG[to] = CONFIG[from]
		end
	end

	alias("EnableKeywordHazardDetection", "EnableAcidNameDetection")
	alias("EnableWorkspaceHazardCache", "EnableWorkspaceAcidCache")

	if CONFIG.RedirectOnlyWhenRagdolled then
		CONFIG.EnableStandingSlide = false
		CONFIG.EnableStandingVelocitySlide = false
	else
		alias("EnableStandingSlidePrediction", "EnableStandingSlide")
		alias("EnableStandingVelocitySlidePrediction", "EnableStandingVelocitySlide")
	end
end

applyConfigAliases()

