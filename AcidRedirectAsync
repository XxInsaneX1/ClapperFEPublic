local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local global = if getgenv then getgenv() else _G

local loaderOptions = ...
if typeof(loaderOptions) ~= "table" then
	loaderOptions = {}
end

local ExternalPredictPlayerLanding = nil
if typeof(loaderOptions.PredictPlayerLanding) == "function" then
	ExternalPredictPlayerLanding = loaderOptions.PredictPlayerLanding
end

if global.__AcidRedirectController and typeof(global.__AcidRedirectController.Destroy) == "function" then
	pcall(global.__AcidRedirectController.Destroy)
end

