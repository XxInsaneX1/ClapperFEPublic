-- Arc drawing
--------------------------------------------------------------------------

local function getArcFolder()
	local folder = Workspace:FindFirstChild(CONFIG.ArcFolderName)

	if not folder then
		folder = Instance.new("Folder")
		folder.Name = CONFIG.ArcFolderName
		folder.Parent = Workspace
	end

	return folder
end

local function clearTrajectoryArc()
	local folder = Workspace:FindFirstChild(CONFIG.ArcFolderName)
	if folder then
		folder:ClearAllChildren()
	end
end

local function makeArcPart(name, size, color, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = CONFIG.ArcMaterial
	part.Color = color
	part.Transparency = transparency
	part.Size = size
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function cylinderBetween(a, b)
	local midpoint = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawTrajectoryArc(prediction, danger)
	if not CONFIG.ShowTrajectoryArc then
		return
	end

	if not danger and CONFIG.DrawSafeTrajectoryArc == false then
		if CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end
		return
	end

	clearTrajectoryArc()

	if not prediction or typeof(prediction.Trajectory) ~= "table" or #prediction.Trajectory <= 0 then
		return
	end

	local trajectory = prediction.Trajectory
	local folder = getArcFolder()
	local color = danger and CONFIG.ArcDangerColor or CONFIG.ArcSafeColor
	local stride = math.max(math.floor(CONFIG.ArcVisualStride or 1), 1)
	local thickness = CONFIG.ArcThickness or 0.12
	local transparency = CONFIG.ArcTransparency or 0.08

	for i = 1, #trajectory - 1, stride do
		local a = trajectory[i]
		local b = trajectory[math.min(i + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local part = makeArcPart("PathLine", Vector3.new(thickness, distance, thickness), color, transparency)
				part.Shape = Enum.PartType.Cylinder
				part.CFrame = cylinderBetween(a, b)
				part.Parent = folder
			end
		end
	end

	local markerPos = prediction.LandPosition or prediction.RootPosition or trajectory[#trajectory]

	if danger and typeof(danger.Position) == "Vector3" then
		markerPos = danger.Position
	end

	if typeof(markerPos) == "Vector3" then
		local marker = makeArcPart(
			"EndMarker",
			Vector3.new(CONFIG.ArcLandingMarkerSize, CONFIG.ArcLandingMarkerSize, CONFIG.ArcLandingMarkerSize),
			danger and CONFIG.ArcDangerColor or CONFIG.ArcEndMarkerColor,
			0.02
		)

		marker.Shape = Enum.PartType.Ball
		marker.CFrame = CFrame.new(markerPos)
		marker.Parent = folder
	end
end

--------------------------------------------------------------------------
-- Acid folder resolving and danger detection
--------------------------------------------------------------------------

local function rebuildAcidParts()
	table.clear(acidParts)
	table.clear(acidPartSet)

	if not acidPitFolder then
		return
	end

	for _, inst in ipairs(acidPitFolder:GetDescendants()) do
		if inst:IsA("BasePart") then
			table.insert(acidParts, inst)
			acidPartSet[inst] = true
		end
	end
end

local function bindAcidFolder(folder)
	disconnectAll(acidFolderConnections)

	if not folder then
		return
	end

	table.insert(acidFolderConnections, folder.DescendantAdded:Connect(function(inst)
		if inst:IsA("BasePart") then
			rebuildAcidParts()
		end
	end))

	table.insert(acidFolderConnections, folder.DescendantRemoving:Connect(function(inst)
		if inst:IsA("BasePart") then
			task.defer(rebuildAcidParts)
		end
	end))
end

local function resolveAcidPitFolder(forceNotify)
	local map = Workspace:FindFirstChild("Map")
	local abnormality = map and map:FindFirstChild("AcidAbnormality")
	local found = abnormality and abnormality:FindFirstChild("AcidPit")

	if found and found ~= acidPitFolder then
		acidPitFolder = found
		acidOverlapParams.FilterDescendantsInstances = { acidPitFolder }
		bindAcidFolder(acidPitFolder)
		rebuildAcidParts()

		if forceNotify then
			notify("Real AcidPit folder synced.", 2.5)
		end
	end

	if not acidPitFolder then
		local fallback = Workspace:FindFirstChild("__MissingAcidPitFallback")

		if not fallback then
			fallback = Instance.new("Folder")
			fallback.Name = "__MissingAcidPitFallback"
			fallback.Parent = Workspace
		end

		acidPitFolder = fallback
		acidOverlapParams.FilterDescendantsInstances = { acidPitFolder }
		bindAcidFolder(acidPitFolder)
		rebuildAcidParts()
	end
end

local function textHasDangerKeyword(text)
	if typeof(text) ~= "string" then
		return false
	end

	local lowered = string.lower(text)

	for _, keyword in ipairs(CONFIG.DangerKeywords) do
		if string.find(lowered, string.lower(keyword), 1, true) then
			return true
		end
	end

	return false
end

local function attributesMentionDanger(instance)
	if not instance or not instance.GetAttributes then
		return false
	end

	local ok, attributes = pcall(function()
		return instance:GetAttributes()
	end)

	if not ok or typeof(attributes) ~= "table" then
		return false
	end

	for key, value in pairs(attributes) do
		if textHasDangerKeyword(tostring(key)) or textHasDangerKeyword(tostring(value)) then
			return true
		end
	end

	return false
end

local function descendantsMentionDanger(instance)
	if not instance then
		return false
	end

	local scanned = 0

	for _, descendant in ipairs(instance:GetDescendants()) do
		scanned += 1
		if scanned > CONFIG.DangerDescendantScanLimit then
			break
		end

		if textHasDangerKeyword(descendant.Name) or attributesMentionDanger(descendant) then
			return true
		end
	end

	return false
end

local function ancestryMentionsDanger(instance)
	local current = instance
	local depth = 0

	while current and current ~= Workspace and depth < 8 do
		depth += 1

		if textHasDangerKeyword(current.Name) or attributesMentionDanger(current) then
			return true
		end

		current = current.Parent
	end

	return false
end

local function isDangerousInstanceRaw(instance)
	if not instance then
		return false
	end

	if acidPitFolder and instance:IsDescendantOf(acidPitFolder) then
		return true
	end

	if CONFIG.EnableKeywordHazardDetection == false then
		return false
	end

	return ancestryMentionsDanger(instance) or descendantsMentionDanger(instance)
end

local function isDangerousInstance(instance)
	if not instance then
		return false
	end

	local now = os.clock()
	local cachedAt = dangerCacheTimes[instance]

	if cachedAt and now - cachedAt < CONFIG.DangerCacheLifetime then
		return dangerCache[instance] == true
	end

	local result = isDangerousInstanceRaw(instance)

	dangerCache[instance] = result
	dangerCacheTimes[instance] = now

	return result
end

local function pointInsidePartBounds(point, part, padding)
	local localPoint = part.CFrame:PointToObjectSpace(point)
	local half = part.Size * 0.5

	return math.abs(localPoint.X) <= half.X + padding
		and math.abs(localPoint.Y) <= half.Y + padding
		and math.abs(localPoint.Z) <= half.Z + padding
end

local function getDangerNearPoint(point, radius)
	if acidPitFolder and overlapSupported then
		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, radius, acidOverlapParams)
		end)

		if ok then
			for _, part in ipairs(parts) do
				if isDangerousInstance(part) then
					return part
				end
			end
		else
			overlapSupported = false
		end
	end

	for _, part in ipairs(acidParts) do
		if part.Parent and pointInsidePartBounds(point, part, radius) then
			return part
		end
	end

	if CONFIG.EnableBroadHazardScan and CONFIG.EnableKeywordHazardDetection then
		local broadRadius = math.max(radius, CONFIG.BroadHazardScanRadius)

		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, broadRadius, broadHazardOverlapParams)
		end)

		if ok then
			for _, part in ipairs(parts) do
				if part:IsA("BasePart") and isDangerousInstance(part) then
					return part
				end
			end
		end
	end

	return nil
end

local function getNearestAcidDistance(position)
	local nearest = math.huge

	for _, part in ipairs(acidParts) do
		if part.Parent then
			local localPoint = part.CFrame:PointToObjectSpace(position)
			local half = part.Size * 0.5

			local dx = math.max(math.abs(localPoint.X) - half.X, 0)
			local dy = math.max(math.abs(localPoint.Y) - half.Y, 0)
			local dz = math.max(math.abs(localPoint.Z) - half.Z, 0)

			nearest = math.min(nearest, Vector3.new(dx, dy, dz).Magnitude)
		end
	end

	return nearest
end

--------------------------------------------------------------------------
-- Prediction
--------------------------------------------------------------------------

local function horizontal(v)
	return Vector3.new(v.X, 0, v.Z)
end

local function safeSpherecast(origin, radius, displacement, params)
	local ok, result = pcall(function()
		return Workspace:Spherecast(origin, radius, displacement, params)
	end)

	if ok then
		return result
	end

	return Workspace:Raycast(origin, displacement, params)
end

local function getMass()
	if rootPart and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end

	return 70
end

local function getDragAcceleration(velocity)
	local speed = velocity.Magnitude
	if speed <= 0.001 then
		return Vector3.zero
	end

	local drag = 0.5 * CONFIG.AirDensity * CONFIG.DragCoefficient * CONFIG.CrossSectionArea * speed * speed
	return -velocity.Unit * (drag / getMass())
end

local function getMagnusAcceleration(velocity, angularVelocity)
	if velocity.Magnitude <= 0.001 or angularVelocity.Magnitude <= 0.001 or CONFIG.MagnusCoefficient <= 0 then
		return Vector3.zero
	end

	local magnus = angularVelocity:Cross(velocity) * CONFIG.MagnusCoefficient

	if magnus.Magnitude > CONFIG.MaxMagnusAcceleration then
		magnus = magnus.Unit * CONFIG.MaxMagnusAcceleration
	end

	return magnus
end

local function predictTrajectoryInternal()
	if not rootPart or not rootPart.Parent then
		return nil
	end

	local position = rootPart.Position
	local velocity = rootPart.AssemblyLinearVelocity
	local angular = rootPart.AssemblyAngularVelocity
	local gravity = Vector3.new(0, -Workspace.Gravity, 0)
	local trajectory = { position }

	local elapsed = 0
	local stepIndex = 0

	while elapsed < CONFIG.PredictionMaxTime do
		stepIndex += 1

		local step = math.min(CONFIG.PredictionTimeStep, CONFIG.PredictionMaxTime - elapsed)
		local acceleration = gravity + getDragAcceleration(velocity) + getMagnusAcceleration(velocity, angular)
		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position

		if displacement.Magnitude > 0.001 then
			local hit = safeSpherecast(position, CONFIG.CharacterRadius, displacement, raycastParams)

			if hit then
				local alpha = math.clamp(hit.Distance / displacement.Magnitude, 0, 1)
				local rootPos = position:Lerp(nextPosition, alpha)

				table.insert(trajectory, rootPos)

				return {
					Trajectory = trajectory,
					HitResult = hit,
					HitPart = hit.Instance,
					LandPosition = hit.Position,
					RootPosition = rootPos,
					LandNormal = hit.Normal,
					Time = elapsed + step * alpha,
					Velocity = velocity:Lerp(nextVelocity, alpha),
					Source = "Internal",
				}
			end
		end

		if stepIndex % math.max(CONFIG.TrajectorySampleStride, 1) == 0 then
			table.insert(trajectory, nextPosition)

			local dangerPart = getDangerNearPoint(nextPosition, CONFIG.TrajectoryDangerRadius)
			if dangerPart then
				return {
					Trajectory = trajectory,
					HitResult = nil,
					HitPart = dangerPart,
					LandPosition = nextPosition,
					RootPosition = nextPosition,
					Time = elapsed + step,
					Velocity = nextVelocity,
					NearDangerPart = dangerPart,
					Source = "Internal",
				}
			end
		end

		position = nextPosition
		velocity = nextVelocity
		elapsed += step
	end

	return {
		Trajectory = trajectory,
		HitResult = nil,
		HitPart = nil,
		LandPosition = position,
		RootPosition = position,
		Time = CONFIG.PredictionMaxTime,
		Velocity = velocity,
		Source = "Internal",
	}
end

local function predictTrajectoryExternal()
	if not ExternalPredictPlayerLanding then
		return nil
	end

	local ok, trajectory, hitPart, hitResult, prediction = pcall(ExternalPredictPlayerLanding, LocalPlayer, {
		MaxTime = CONFIG.PredictionMaxTime,
		TimeStep = CONFIG.PredictionTimeStep,
		Gravity = Workspace.Gravity,

		AirDensity = CONFIG.AirDensity,
		DragCoefficient = CONFIG.DragCoefficient,
		CrossSectionArea = CONFIG.CrossSectionArea,
		MagnusCoefficient = CONFIG.MagnusCoefficient,
		MaxMagnusAcceleration = CONFIG.MaxMagnusAcceleration,

		CastMode = "Sphere",
		CastRadius = CONFIG.CharacterRadius,
		CastPadding = 0.05,
		IgnoreWater = true,

		DrawArc = false,
		ClearArc = false,
	})

	if not ok then
		Controller.LastError = tostring(trajectory)
		return nil
	end

	if typeof(prediction) ~= "table" then
		return nil
	end

	prediction.Trajectory = prediction.Trajectory or trajectory or {}
	prediction.HitPart = prediction.HitPart or hitPart
	prediction.HitResult = prediction.HitResult or hitResult
	prediction.Source = "External"

	return prediction
end

local function predictTrajectory()
	return predictTrajectoryExternal() or predictTrajectoryInternal()
end

--------------------------------------------------------------------------
-- Danger classification and slide prediction
--------------------------------------------------------------------------

local function getSurfaceVelocity(velocity, normal)
	return velocity - normal * velocity:Dot(normal)
end

local function getGroundHit(position)
	local origin = position + Vector3.new(0, CONFIG.SlideProbeHeight * 0.5, 0)
	local displacement = Vector3.new(0, -CONFIG.SlideProbeHeight, 0)
	return safeSpherecast(origin, CONFIG.SlideProbeRadius, displacement, raycastParams)
end

local function getSurfaceFriction(part)
	if not part or not part:IsA("BasePart") then
		return CONFIG.DefaultSurfaceFriction
	end

	local props = part.CurrentPhysicalProperties
	local friction = props and props.Friction or CONFIG.DefaultSurfaceFriction

	if typeof(friction) ~= "number" or friction <= 0 then
		return CONFIG.DefaultSurfaceFriction
	end

	return friction
end

local function simulateSlideDanger(prediction)
	if not CONFIG.EnableSlidePrediction or not isRagdolled() or not prediction or not rootPart then
		return nil
	end

	local groundHit = prediction.HitResult or getGroundHit(prediction.RootPosition or prediction.LandPosition or rootPart.Position)
	if not groundHit then
		return nil
	end

	if isDangerousInstance(groundHit.Instance) then
		return {
			Kind = "SlideGround",
			Part = groundHit.Instance,
			Position = groundHit.Position,
			Prediction = prediction,
		}
	end

	local normal = groundHit.Normal
	if normal.Y <= 0.05 then
		return nil
	end

	local position = prediction.RootPosition or prediction.LandPosition or groundHit.Position
	local velocity = prediction.Velocity or rootPart.AssemblyLinearVelocity
	local slideVelocity = getSurfaceVelocity(velocity, normal)
	local elapsed = 0

	while elapsed < CONFIG.SlideLookahead do
		local step = math.min(CONFIG.SlideTimeStep, CONFIG.SlideLookahead - elapsed)
		local gravity = Vector3.new(0, -Workspace.Gravity, 0)
		local slopeAcceleration = gravity - normal * gravity:Dot(normal)
		local normalAcceleration = math.max(-gravity:Dot(normal), 0)

		local friction = getSurfaceFriction(groundHit.Instance) * CONFIG.RagdollFrictionMultiplier
		local staticFriction = friction * CONFIG.StaticFrictionMultiplier

		if slideVelocity.Magnitude < CONFIG.MinSlideSpeed and slopeAcceleration.Magnitude <= staticFriction * normalAcceleration then
			return nil
		end

		slideVelocity += slopeAcceleration * step

		if slideVelocity.Magnitude > 0.001 then
			local frictionMag = math.min(friction * normalAcceleration, slideVelocity.Magnitude / step)
			slideVelocity -= slideVelocity.Unit * frictionMag * step
		end

		if slideVelocity.Magnitude > CONFIG.MaxSlideSpeed then
			slideVelocity = slideVelocity.Unit * CONFIG.MaxSlideSpeed
		end

		if slideVelocity.Magnitude < 0.25 and slopeAcceleration.Magnitude < CONFIG.MinSlideSpeed then
			return nil
		end

		position += slideVelocity * step

		local dangerPart = getDangerNearPoint(position, CONFIG.SlideDangerRadius)
		if dangerPart then
			return {
				Kind = "SlideOverlap",
				Part = dangerPart,
				Position = position,
				Prediction = prediction,
			}
		end

		groundHit = getGroundHit(position + normal * CONFIG.SlideSurfaceOffset)
		if not groundHit then
			return nil
		end

		if isDangerousInstance(groundHit.Instance) then
			return {
				Kind = "SlideGround",
				Part = groundHit.Instance,
				Position = groundHit.Position,
				Prediction = prediction,
			}
		end

		normal = groundHit.Normal
		position = groundHit.Position + normal * CONFIG.SlideSurfaceOffset
		slideVelocity = getSurfaceVelocity(slideVelocity, normal)

		elapsed += step
	end

	return nil
end

local function scanTrajectoryForDanger(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then
		return nil
	end

	local stride = math.max(math.floor(CONFIG.TrajectorySampleStride or 1), 1)

	for i = 1, #prediction.Trajectory, stride do
		local point = prediction.Trajectory[i]

		if typeof(point) == "Vector3" then
			local dangerPart = getDangerNearPoint(point, CONFIG.TrajectoryDangerRadius)
			if dangerPart then
				return {
					Kind = "AirPath",
					Part = dangerPart,
					Position = point,
					Prediction = prediction,
				}
			end
		end
	end

	return nil
end

local function getPredictionDanger(prediction)
	if not isRagdolled() or not prediction then
		return nil
	end

	if prediction.NearDangerPart then
		return {
			Kind = "AirPath",
			Part = prediction.NearDangerPart,
			Position = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	local air = scanTrajectoryForDanger(prediction)
	if air then
		return air
	end

	local hitPart = prediction.HitPart or (prediction.HitResult and prediction.HitResult.Instance)

	if isDangerousInstance(hitPart) then
		return {
			Kind = "DirectHit",
			Part = hitPart,
			Position = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	return simulateSlideDanger(prediction)
end

--------------------------------------------------------------------------
-- Redirect
--------------------------------------------------------------------------

local function getClosestPointOnPartBounds(part, point)
	if not part or not part:IsA("BasePart") then
		return nil
	end

	local localPoint = part.CFrame:PointToObjectSpace(point)
	local half = part.Size * 0.5

	local clamped = Vector3.new(
		math.clamp(localPoint.X, -half.X, half.X),
		math.clamp(localPoint.Y, -half.Y, half.Y),
		math.clamp(localPoint.Z, -half.Z, half.Z)
	)

	return part.CFrame:PointToWorldSpace(clamped)
end

local function getEscapeDirectionFromPart(part, point)
	if not part or not part:IsA("BasePart") then
		return nil
	end

	local closest = getClosestPointOnPartBounds(part, point)

	if closest then
		local away = horizontal(point - closest)
		if away.Magnitude > 0.001 then
			return away.Unit
		end
	end

	local localPoint = part.CFrame:PointToObjectSpace(point)
	local half = part.Size * 0.5

	local options = {
		{ D = math.abs(half.X - localPoint.X), Dir = Vector3.new(1, 0, 0) },
		{ D = math.abs(-half.X - localPoint.X), Dir = Vector3.new(-1, 0, 0) },
		{ D = math.abs(half.Z - localPoint.Z), Dir = Vector3.new(0, 0, 1) },
		{ D = math.abs(-half.Z - localPoint.Z), Dir = Vector3.new(0, 0, -1) },
	}

	table.sort(options, function(a, b)
		return a.D < b.D
	end)

	local dir = horizontal(part.CFrame:VectorToWorldSpace(options[1].Dir))
	return dir.Magnitude > 0.001 and dir.Unit or nil
end

local function getDangerDistance(danger)
	if not rootPart or not danger then
		return math.huge
	end

	if typeof(danger.Position) == "Vector3" then
		return (rootPart.Position - danger.Position).Magnitude
	end

	if danger.Part and danger.Part:IsA("BasePart") then
		local closest = getClosestPointOnPartBounds(danger.Part, rootPart.Position)
		if closest then
			return (rootPart.Position - closest).Magnitude
		end
	end

	return math.huge
end

local function getDangerTime(danger)
	if danger and danger.Prediction and typeof(danger.Prediction.Time) == "number" then
		return danger.Prediction.Time
	end

	return math.huge
end

local function getSafeVelocity(danger)
	local currentVelocity = rootPart.AssemblyLinearVelocity
	local currentHorizontal = horizontal(currentVelocity)

	local desired

	if danger.Part and danger.Part:IsA("BasePart") then
		desired = getEscapeDirectionFromPart(danger.Part, rootPart.Position)
	end

	if not desired and typeof(danger.Position) == "Vector3" then
		local away = horizontal(rootPart.Position - danger.Position)
		if away.Magnitude > 0.001 then
			desired = away.Unit
		end
	end

	if not desired and currentHorizontal.Magnitude > 0.001 then
		desired = -currentHorizontal.Unit
	end

	if not desired then
		local look = horizontal(rootPart.CFrame.LookVector)
		desired = look.Magnitude > 0.001 and look.Unit or Vector3.new(1, 0, 0)
	end

	local side = Vector3.new(-desired.Z, 0, desired.X)
	if side.Magnitude > 0.001 then
		if currentHorizontal.Magnitude > 0.001 and currentHorizontal:Dot(side) < 0 then
			side = -side
		end
		desired = (desired + side.Unit * CONFIG.SideBias).Unit
	end

	local dangerDistance = getDangerDistance(danger)
	local dangerTime = getDangerTime(danger)

	local emergency = dangerDistance <= CONFIG.EmergencyRedirectDistance or dangerTime <= CONFIG.EmergencyRedirectTime

	local horizontalSpeed = math.clamp(
		math.max(currentHorizontal.Magnitude, emergency and CONFIG.RedirectMaxHorizontalSpeed or CONFIG.RedirectHorizontalSpeed),
		CONFIG.RedirectHorizontalSpeed,
		CONFIG.RedirectMaxHorizontalSpeed
	)

	local lift = string.find(danger.Kind or "", "Slide") and CONFIG.SlideRedirectLift or CONFIG.RedirectLift

	if emergency then
		lift = math.max(lift, CONFIG.RedirectLift + 8)
	end

	local targetY = math.max(currentVelocity.Y, lift)

	if currentVelocity.Y < -20 then
		targetY = math.max(targetY, 24)
	end

	return desired * horizontalSpeed + Vector3.new(0, targetY, 0)
end

local function applyRedirect(deltaTime)
	if not rootPart or not rootPart.Parent or not Controller.LastDanger then
		return
	end

	if not isRagdolled() then
		Controller.LastDanger = nil
		Controller.LastPrediction = nil

		if CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end

		return
	end

	notifyThrottled("attempting_redirect", "Attempting redirect to safety", 2.5)

	local currentVelocity = rootPart.AssemblyLinearVelocity
	local targetVelocity = getSafeVelocity(Controller.LastDanger)

	local emergency = getDangerDistance(Controller.LastDanger) <= CONFIG.EmergencyRedirectDistance
		or getDangerTime(Controller.LastDanger) <= CONFIG.EmergencyRedirectTime

	local alpha

	if emergency then
		alpha = CONFIG.EmergencyRedirectAlpha
	else
		alpha = 1 - math.exp(-CONFIG.RedirectResponsiveness * deltaTime)
		alpha = math.max(alpha, CONFIG.NormalRedirectMinAlpha)
	end

	local newVelocity = currentVelocity:Lerp(targetVelocity, math.clamp(alpha, 0, 1))
	rootPart.AssemblyLinearVelocity = newVelocity

	if CONFIG.ImpulseAssist and rootPart.AssemblyMass > 0 then
		local deltaVelocity = newVelocity - currentVelocity

		if deltaVelocity.Magnitude > 0.001 then
			pcall(function()
				rootPart:ApplyImpulse(deltaVelocity * rootPart.AssemblyMass * CONFIG.ImpulseMultiplier)
			end)
		end
	end
end

--------------------------------------------------------------------------
-- Heartbeat
--------------------------------------------------------------------------

local function updateNearestAcid(deltaTime)
	nearestCheckAccumulated += deltaTime

	if nearestCheckAccumulated < 0.35 then
		return
	end

	nearestCheckAccumulated = 0

	if rootPart then
		nearestAcidDistance = getNearestAcidDistance(rootPart.Position)
	else
		nearestAcidDistance = math.huge
	end
end

local function shouldPredict()
	if not rootPart or not rootPart.Parent then
		return false
	end

	if not isRagdolled() then
		return false
	end

	if CONFIG.AlwaysPredictWhileRagdolled then
		return true
	end

	local velocity = rootPart.AssemblyLinearVelocity

	if velocity.Magnitude >= CONFIG.MinSpeedToPredict then
		return true
	end

	if getDangerNearPoint(rootPart.Position, CONFIG.SlideDangerRadius) then
		return true
	end

	if nearestAcidDistance <= CONFIG.ActivationDistance then
		return true
	end

	return false
end

local function onHeartbeat(deltaTime)
	if not Controller.Enabled then
		Controller.LastDanger = nil
		Controller.LastPrediction = nil

		if CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end

		return
	end

	acidResolveAccumulated += deltaTime
	if acidResolveAccumulated >= 1 then
		acidResolveAccumulated = 0
		resolveAcidPitFolder(false)
	end

	if not character
		or not character.Parent
		or not humanoid
		or not humanoid.Parent
		or not rootPart
		or not rootPart.Parent then
		setupCharacter(LocalPlayer.Character)
	end

	if not isRagdolled() then
		Controller.LastDanger = nil
		Controller.LastPrediction = nil
		lastDangerUntil = 0

		if CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end

		return
	end

	updateNearestAcid(deltaTime)
	accumulated += deltaTime

	if accumulated >= CONFIG.PredictEvery then
		accumulated = 0

		if shouldPredict() then
			local prediction = predictTrajectory()

			if prediction then
				local danger = getPredictionDanger(prediction)

				Controller.LastPrediction = prediction
				drawTrajectoryArc(prediction, danger)

				if danger then
					if not Controller.LastDanger then
						notifyThrottled("trajectory_detected", "Trajectory detected toward hazard", 2.5)
					end

					Controller.LastDanger = danger

					local emergency = getDangerDistance(danger) <= CONFIG.EmergencyRedirectDistance
						or getDangerTime(danger) <= CONFIG.EmergencyRedirectTime

					lastDangerUntil = os.clock() + (emergency and math.max(CONFIG.ApplyWindow, 0.65) or CONFIG.ApplyWindow)
				elseif os.clock() > lastDangerUntil then
					Controller.LastDanger = nil
				end
			end
		elseif os.clock() > lastDangerUntil then
			Controller.LastDanger = nil
			Controller.LastPrediction = nil

			if CONFIG.ClearArcWhenIdle then
				clearTrajectoryArc()
			end
		end
	end

	if Controller.LastDanger and os.clock() <= lastDangerUntil then
		applyRedirect(deltaTime)
	end
end

--------------------------------------------------------------------------
-- Controller API
--------------------------------------------------------------------------

function Controller.Start()
	Controller.Enabled = true
	CONFIG.Enabled = true
end

function Controller.Stop()
	Controller.Enabled = false
	CONFIG.Enabled = false
	Controller.LastDanger = nil
	Controller.LastPrediction = nil
	lastDangerUntil = 0

	if CONFIG.ClearArcWhenIdle then
		clearTrajectoryArc()
	end
end

function Controller.ShowArc()
	CONFIG.ShowTrajectoryArc = true
end

function Controller.HideArc()
	CONFIG.ShowTrajectoryArc = false
	clearTrajectoryArc()
end

function Controller.ClearArc()
	clearTrajectoryArc()
end

function Controller.SetConfig(nextConfig)
	if typeof(nextConfig) ~= "table" then
		return
	end

	for k, v in pairs(nextConfig) do
		CONFIG[k] = v
	end

	CONFIG.RagdollOnly = true
	CONFIG.EnableStandingSlidePrediction = false
	CONFIG.EnableStandingVelocitySlidePrediction = false
	CONFIG.EnableRagdollSlidePrediction = true
end

function Controller.SetPredictor(predictor)
	if typeof(predictor) == "function" then
		ExternalPredictPlayerLanding = predictor
		Controller.UsingExternalTrajectoryApi = true
	else
		ExternalPredictPlayerLanding = nil
		Controller.UsingExternalTrajectoryApi = false
	end
end

function Controller.IsRedirecting()
	return Controller.Enabled == true
		and Controller.LastDanger ~= nil
		and os.clock() <= lastDangerUntil
		and isRagdolled()
end

function Controller.Destroy()
	Controller.Stop()

	disconnectAll(connections)
	disconnectAll(acidFolderConnections)

	if heartbeatConnection then
		pcall(function()
			heartbeatConnection:Disconnect()
		end)

		heartbeatConnection = nil
	end

	clearTrajectoryArc()

	if global.__AcidRedirectController == Controller then
		global.__AcidRedirectController = nil
	end
end

--------------------------------------------------------------------------
-- Init
--------------------------------------------------------------------------

resolveAcidPitFolder(false)
setupCharacter(LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait())

table.insert(connections, LocalPlayer.CharacterAdded:Connect(function(nextCharacter)
	task.defer(setupCharacter, nextCharacter)
end))

heartbeatConnection = RunService.Heartbeat:Connect(onHeartbeat)

global.__AcidRedirectController = Controller

return Controller
