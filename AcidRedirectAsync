local notifyTimes = {}

local function notifyAcid(message, duration)
	if not NotifyCallback then return end
	pcall(function()
		NotifyCallback("Acid-Redirect", message, duration or 2.5)
	end)
end

local function notifyAcidThrottled(key, message, duration)
	if CONFIG.EnableNotifications == false then return end

	local now  = os.clock()
	local last = notifyTimes[key]

	if last and now - last < CONFIG.NotificationCooldown then
		return
	end

	notifyTimes[key] = now
	notifyAcid(message, duration)
end

------------------------------------------------------------------------
-- Acid folder discovery
------------------------------------------------------------------------

local function textMentionsAcid(text)
	if typeof(text) ~= "string" then return false end

	local lowered = string.lower(text)

	for _, keyword in ipairs(CONFIG.AcidKeywords) do
		if string.find(lowered, string.lower(keyword), 1, true) then
			return true
		end
	end

	return false
end

local function attributesMentionAcid(instance)
	if not CONFIG.EnableAcidAttributeDetection then return false end
	if not instance or not instance.GetAttributes then return false end

	local ok, attributes = pcall(function()
		return instance:GetAttributes()
	end)

	if not ok or typeof(attributes) ~= "table" then
		return false
	end

	for key, value in pairs(attributes) do
		if textMentionsAcid(tostring(key)) or textMentionsAcid(tostring(value)) then
			return true
		end
	end

	return false
end

local function ancestryMentionsAcid(instance)
	if not CONFIG.EnableAcidNameDetection then return false end

	local current = instance
	local depth = 0

	while current and current ~= Workspace and depth < 12 do
		depth += 1

		if textMentionsAcid(current.Name) or attributesMentionAcid(current) then
			return true
		end

		current = current.Parent
	end

	return false
end

local function descendantsMentionAcid(instance)
	if not CONFIG.EnableAcidNameDetection then return false end
	if not instance then return false end

	local scanned = 0

	for _, descendant in ipairs(instance:GetDescendants()) do
		scanned += 1
		if scanned > CONFIG.AcidDescendantScanLimit then
			break
		end

		if textMentionsAcid(descendant.Name) or attributesMentionAcid(descendant) then
			return true
		end
	end

	return false
end

local function findDefaultAcidPitFolder()
	local map = Workspace:FindFirstChild("Map")
	local acidAbnormality = map and map:FindFirstChild("AcidAbnormality") or nil
	local acidPit = acidAbnormality and acidAbnormality:FindFirstChild("AcidPit") or nil

	if acidPit then
		return acidPit
	end

	for _, instance in ipairs(Workspace:GetChildren()) do
		if textMentionsAcid(instance.Name) then
			if instance:IsA("Folder") or instance:IsA("Model") then
				return instance
			end
		end
	end

	return nil
end

local acidPitFolder = findDefaultAcidPitFolder()

