local function pointInsidePartBounds(point, part, padding)
	local localPoint = part.CFrame:PointToObjectSpace(point)
	local halfSize = part.Size * 0.5

	return math.abs(localPoint.X) <= halfSize.X + padding
		and math.abs(localPoint.Y) <= halfSize.Y + padding
		and math.abs(localPoint.Z) <= halfSize.Z + padding
end

local function getAcidNearPoint(point, radius)
	if #acidParts > 0 and overlapSupported then
		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, radius, acidOverlapParams)
		end)

		if ok and parts then
			for _, p in ipairs(parts) do
				if p:IsA("BasePart") and isAcidInstance(p) then
					return p
				end
			end
		else
			overlapSupported = false
		end
	end

	for _, p in ipairs(acidParts) do
		if p.Parent and pointInsidePartBounds(point, p, radius) then
			return p
		end
	end

	if CONFIG.EnableBroadHazardScan then
		local ok, parts = pcall(function()
			return Workspace:GetPartBoundsInRadius(point, math.max(radius, 9), broadOverlapParams)
		end)

		if ok and parts then
			for _, p in ipairs(parts) do
				if p:IsA("BasePart") and isAcidInstance(p) then
					addAcidPart(p)
					return p
				end
			end
		end
	end

	return nil
end

local function getNearestAcidDirectionAway(position)
	local nearestPart = nil
	local nearestDistance = math.huge
	local nearestPoint = nil

	for _, p in ipairs(acidParts) do
		if p.Parent then
			local localPoint = p.CFrame:PointToObjectSpace(position)
			local halfSize = p.Size * 0.5

			local clampedLocal = Vector3.new(
				math.clamp(localPoint.X, -halfSize.X, halfSize.X),
				math.clamp(localPoint.Y, -halfSize.Y, halfSize.Y),
				math.clamp(localPoint.Z, -halfSize.Z, halfSize.Z)
			)

			local worldPoint = p.CFrame:PointToWorldSpace(clampedLocal)
			local distance = (position - worldPoint).Magnitude

			if distance < nearestDistance then
				nearestDistance = distance
				nearestPart = p
				nearestPoint = worldPoint
			end
		end
	end

	if nearestPoint then
		local away = position - nearestPoint
		away = Vector3.new(away.X, 0, away.Z)

		if away.Magnitude > 0.001 then
			return away.Unit, nearestPart, nearestDistance
		end
	end

	return nil, nearestPart, nearestDistance
end

local function getHorizontal(v)
	return Vector3.new(v.X, 0, v.Z)
end

local function safeHorizontalUnit(v, fallback)
	local h = getHorizontal(v)

	if h.Magnitude > 0.001 then
		return h.Unit
	end

	return fallback or Vector3.new(0, 0, -1)
end

local function getMass()
	if rootPart and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end

	return 70
end

local function getDragAcceleration(velocity)
	local speed = velocity.Magnitude

	if speed <= 0.001 then
		return Vector3.zero
	end

	local drag = 0.5 * CONFIG.AirDensity * CONFIG.DragCoefficient * CONFIG.CrossSectionArea * speed * speed
	return -velocity.Unit * (drag / getMass())
end

local function getMagnusAcceleration(velocity, angularVelocity)
	if velocity.Magnitude <= 0.001 or angularVelocity.Magnitude <= 0.001 or CONFIG.MagnusCoefficient <= 0 then
		return Vector3.zero
	end

	local magnus = angularVelocity:Cross(velocity) * CONFIG.MagnusCoefficient

	if magnus.Magnitude > CONFIG.MaxMagnusAcceleration then
		magnus = magnus.Unit * CONFIG.MaxMagnusAcceleration
	end

	return magnus
end

local function predictTrajectoryInternal()
	if not rootPart or not rootPart.Parent then return nil end

	local position = rootPart.Position
	local velocity = rootPart.AssemblyLinearVelocity
	local angularVelocity = rootPart.AssemblyAngularVelocity
	local gravity = Vector3.new(0, -Workspace.Gravity, 0)

	local trajectory = { position }
	local elapsed = 0
	local stepIndex = 0

	while elapsed < CONFIG.PredictionMaxTime do
		stepIndex += 1

		local step = math.min(CONFIG.PredictionTimeStep, CONFIG.PredictionMaxTime - elapsed)
		local acceleration = gravity + getDragAcceleration(velocity) + getMagnusAcceleration(velocity, angularVelocity)
		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position

		if displacement.Magnitude > 0.001 then
			local hitResult

			local castOk, castResult = pcall(function()
				return Workspace:Spherecast(position, CONFIG.CharacterRadius, displacement, raycastParams)
			end)

			if castOk then
				hitResult = castResult
			else
				hitResult = Workspace:Raycast(position, displacement, raycastParams)
			end

			if hitResult then
				local alpha = math.clamp(hitResult.Distance / displacement.Magnitude, 0, 1)
				local rootPosition = position:Lerp(nextPosition, alpha)

				table.insert(trajectory, rootPosition)

				return {
					Trajectory = trajectory,
					HitResult = hitResult,
					HitPart = hitResult.Instance,
					LandPosition = hitResult.Position,
					RootPosition = rootPosition,
					LandNormal = hitResult.Normal,
					Time = elapsed + step * alpha,
					Velocity = velocity:Lerp(nextVelocity, alpha),
					Source = "Internal",
				}
			end
		end

		if stepIndex % CONFIG.TrajectorySampleStride == 0 then
			table.insert(trajectory, nextPosition)

			local acidPart = getAcidNearPoint(nextPosition, CONFIG.TrajectoryAcidRadius)

			if acidPart then
				return {
					Trajectory = trajectory,
					HitResult = nil,
					HitPart = acidPart,
					LandPosition = nextPosition,
					RootPosition = nextPosition,
					Time = elapsed + step,
					Velocity = nextVelocity,
					NearAcidPart = acidPart,
					Source = "Internal",
				}
			end
		end

		position = nextPosition
		velocity = nextVelocity
		elapsed += step
	end

	return {
		Trajectory = trajectory,
		HitResult = nil,
		HitPart = nil,
		LandPosition = position,
		RootPosition = position,
		Time = CONFIG.PredictionMaxTime,
		Velocity = velocity,
		Source = "Internal",
	}
end

local function predictTrajectoryExternal()
	if not ExternalPredictPlayerLanding then return nil end

	local ok, trajectory, hitPart, hitResult, prediction = pcall(ExternalPredictPlayerLanding, LocalPlayer, {
		MaxTime = CONFIG.PredictionMaxTime,
		TimeStep = CONFIG.PredictionTimeStep,
		Gravity = Workspace.Gravity,
		AirDensity = CONFIG.AirDensity,
		DragCoefficient = CONFIG.DragCoefficient,
		CrossSectionArea = CONFIG.CrossSectionArea,
		MagnusCoefficient = CONFIG.MagnusCoefficient,
		MaxMagnusAcceleration = CONFIG.MaxMagnusAcceleration,

		CastMode = "Sphere",
		CastRadius = CONFIG.CharacterRadius,
		CastPadding = 0.05,
		IgnoreWater = true,

		DrawArc = false,
		ClearArc = false,
	})

	if not ok then
		Controller.LastError = tostring(trajectory)
		return nil
	end

	if typeof(prediction) ~= "table" then
		return nil
	end

	prediction.Trajectory = prediction.Trajectory or trajectory or {}
	prediction.HitPart = prediction.HitPart or hitPart
	prediction.HitResult = prediction.HitResult or hitResult
	prediction.Source = "External"

	return prediction
end

local function predictTrajectory()
	if ExternalPredictPlayerLanding then
		local result = predictTrajectoryExternal()
		if result then return result end
	end
	return predictTrajectoryInternal()
end

local function scanTrajectoryForAcid(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then
		return nil
	end

	local trajectory = prediction.Trajectory
	local stride = math.max(CONFIG.TrajectorySampleStride, 1)

	for i = 1, #trajectory, stride do
		local point = trajectory[i]

		if typeof(point) == "Vector3" then
			local acidPart = getAcidNearPoint(point, CONFIG.TrajectoryAcidRadius)

			if acidPart then
				return {
					Kind = "AirPathAcid",
					Part = acidPart,
					Position = point,
					Prediction = prediction,
				}
			end
		end
	end

	return nil
end

local function getSurfaceVelocity(velocity, normal)
	return velocity - normal * velocity:Dot(normal)
end

local function getSurfaceFriction(part)
	if not part or not part:IsA("BasePart") then
		return CONFIG.DefaultSurfaceFriction
	end

	local props = part.CurrentPhysicalProperties
	local friction = props and props.Friction or CONFIG.DefaultSurfaceFriction

	if typeof(friction) ~= "number" or friction <= 0 then
		return CONFIG.DefaultSurfaceFriction
	end

	return friction
end

local function getGroundHit(position)
	local origin = position + Vector3.new(0, CONFIG.SlideProbeHeight * 0.5, 0)
	local displacement = Vector3.new(0, -CONFIG.SlideProbeHeight, 0)

	local ok, result = pcall(function()
		return Workspace:Spherecast(origin, CONFIG.SlideProbeRadius, displacement, raycastParams)
	end)

	if ok then
		return result
	end

	return Workspace:Raycast(origin, displacement, raycastParams)
end

local function simulateSlideAcidDanger(prediction, ragdoll)
	if not CONFIG.EnableSlidePrediction then return nil end
	if CONFIG.RedirectOnlyWhenRagdolled and not ragdoll then return nil end
	if ragdoll and not CONFIG.EnableRagdollSlidePrediction then return nil end
	if not ragdoll and not (CONFIG.EnableStandingSlide or CONFIG.EnableStandingVelocitySlide) then return nil end
	if not prediction or not rootPart then return nil end

	local groundHit = prediction.HitResult

	if not groundHit then
		groundHit = getGroundHit(prediction.RootPosition or prediction.LandPosition or rootPart.Position)
	end

	if not groundHit then
		return nil
	end

	if isAcidInstance(groundHit.Instance) then
		return {
			Kind = "SlideGroundAcid",
			Part = groundHit.Instance,
			Position = groundHit.Position,
			Prediction = prediction,
		}
	end

	local normal = groundHit.Normal
	local position = prediction.RootPosition or prediction.LandPosition or groundHit.Position
	local velocity = prediction.Velocity or rootPart.AssemblyLinearVelocity
	local slideVelocity = getSurfaceVelocity(velocity, normal)
	local frictionScale = ragdoll and CONFIG.RagdollFrictionMultiplier or 1
	local elapsed = 0

	if normal.Y <= 0.05 then
		return nil
	end

	while elapsed < CONFIG.SlideLookahead do
		local step = math.min(CONFIG.SlideTimeStep, CONFIG.SlideLookahead - elapsed)
		local gravity = Vector3.new(0, -Workspace.Gravity, 0)
		local slopeAcceleration = gravity - normal * gravity:Dot(normal)
		local normalAcceleration = math.max(-gravity:Dot(normal), 0)

		local surfaceFriction = getSurfaceFriction(groundHit.Instance)
		local kineticFriction = surfaceFriction * frictionScale
		local staticFriction = kineticFriction * CONFIG.StaticFrictionMultiplier

		if slideVelocity.Magnitude < CONFIG.MinSlideSpeed and slopeAcceleration.Magnitude <= staticFriction * normalAcceleration then
			return nil
		end

		slideVelocity += slopeAcceleration * step

		if slideVelocity.Magnitude > 0.001 then
			local frictionMag = math.min(kineticFriction * normalAcceleration, slideVelocity.Magnitude / step)
			slideVelocity -= slideVelocity.Unit * frictionMag * step
		end

		if slideVelocity.Magnitude > CONFIG.MaxSlideSpeed then
			slideVelocity = slideVelocity.Unit * CONFIG.MaxSlideSpeed
		end

		if slideVelocity.Magnitude < 0.25 and slopeAcceleration.Magnitude < CONFIG.MinSlideSpeed then
			return nil
		end

		position += slideVelocity * step

		local acidPart = getAcidNearPoint(position, CONFIG.SlideDangerRadius)

		if acidPart then
			return {
				Kind = "SlideIntoAcid",
				Part = acidPart,
				Position = position,
				Prediction = prediction,
			}
		end

		groundHit = getGroundHit(position + normal * CONFIG.SlideSurfaceOffset)

		if not groundHit then
			return nil
		end

		if isAcidInstance(groundHit.Instance) then
			return {
				Kind = "SlideGroundAcid",
				Part = groundHit.Instance,
				Position = groundHit.Position,
				Prediction = prediction,
			}
		end

		normal = groundHit.Normal
		position = groundHit.Position + normal * CONFIG.SlideSurfaceOffset
		slideVelocity = getSurfaceVelocity(slideVelocity, normal)
		elapsed += step
	end

	return nil
end

local function getPredictionAcidDanger(prediction, ragdoll)
	if not prediction then return nil end

	if prediction.NearAcidPart then
		return {
			Kind = "AirPathAcid",
			Part = prediction.NearAcidPart,
			Position = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	local airDanger = scanTrajectoryForAcid(prediction)
	if airDanger then return airDanger end

	local hitPart = prediction.HitPart

	if not hitPart and prediction.HitResult then
		hitPart = prediction.HitResult.Instance
	end

	if isAcidInstance(hitPart) then
		return {
			Kind = "DirectAcidHit",
			Part = hitPart,
			Position = prediction.LandPosition or prediction.RootPosition,
			Prediction = prediction,
		}
	end

	return simulateSlideAcidDanger(prediction, ragdoll)
end

local function getArcFolder()
	local folder = Workspace:FindFirstChild(CONFIG.ArcFolderName)

	if not folder then
		folder = Instance.new("Folder")
		folder.Name = CONFIG.ArcFolderName
		folder.Parent = Workspace
	end

	return folder
end

local function makeArcPart(name, size, color, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = CONFIG.ArcMaterial
	part.Color = color
	part.Transparency = transparency
	part.Size = size
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function getCylinderCFrameBetween(a, b)
	local midpoint = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawTrajectoryArc(prediction, danger)
	if not CONFIG.ShowTrajectoryArc then return end

	clearTrajectoryArc()

	if not prediction or typeof(prediction.Trajectory) ~= "table" or #prediction.Trajectory <= 0 then
		return
	end

	local trajectory = prediction.Trajectory
	local folder = getArcFolder()
	local lineColor = danger and CONFIG.ArcDangerColor or CONFIG.ArcSafeColor
	local stride = math.max(CONFIG.ArcVisualStride, 1)

	for i = 1, #trajectory - 1, stride do
		local a = trajectory[i]
		local b = trajectory[math.min(i + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local segment = makeArcPart(
					"AcidPathLine",
					Vector3.new(CONFIG.ArcThickness, distance, CONFIG.ArcThickness),
					lineColor,
					CONFIG.ArcTransparency
				)

				segment.Shape = Enum.PartType.Cylinder
				segment.CFrame = getCylinderCFrameBetween(a, b)
				segment.Parent = folder
			end
		end
	end

	local markerPos = prediction.LandPosition or prediction.RootPosition or trajectory[#trajectory]

	if danger and typeof(danger.Position) == "Vector3" then
		markerPos = danger.Position
	end

	if typeof(markerPos) == "Vector3" then
		local marker = makeArcPart(
			"AcidEndMarker",
			Vector3.new(CONFIG.ArcLandingMarkerSize, CONFIG.ArcLandingMarkerSize, CONFIG.ArcLandingMarkerSize),
			CONFIG.ArcEndMarkerColor,
			0.02
		)

		marker.Shape = Enum.PartType.Ball
		marker.CFrame = CFrame.new(markerPos)
		marker.Parent = folder
	end
end

local function pushVelocity(velocity, angularVelocity, withImpulse, applySpin)
	if not rootPart or not rootPart.Parent then return end

	local currentVel = rootPart.AssemblyLinearVelocity

	pcall(function()
		rootPart.AssemblyLinearVelocity = velocity
	end)

	pcall(function()
		rootPart.Velocity = velocity
	end)

	if applySpin and CONFIG.PreserveOriginalSpin and angularVelocity then
		pcall(function()
			rootPart.AssemblyAngularVelocity = angularVelocity
		end)
	end

	if withImpulse and CONFIG.ImpulseAssist then
		local mass = getMass()
		local deltaV = velocity - currentVel
		local baseImpulse = deltaV * mass * CONFIG.ImpulseMultiplier
		local maxImpulseMag = math.max(2000, mass * CONFIG.ImpulseCapPerMass)

		if baseImpulse.Magnitude > maxImpulseMag then
			baseImpulse = baseImpulse.Unit * maxImpulseMag
		end

		for i = 1, CONFIG.ImpulseBurstCount do
			local factor = 1 / i

			pcall(function()
				rootPart:ApplyImpulse(baseImpulse * (0.6 * factor))
			end)

			if i < CONFIG.ImpulseBurstCount then
				task.wait(CONFIG.ImpulseBurstInterval)
			end
		end
	end
end

local function applyRedirectVelocity(velocity, angularVelocity, applySpin)
	pushVelocity(velocity, angularVelocity, true, applySpin)

	safePathFound = true
	safePathFoundAt = os.clock()
	safePathVelocity = velocity
	safePathHasSpin = applySpin == true and angularVelocity ~= nil
	safePathAngularVelocity = angularVelocity or rootPart.AssemblyAngularVelocity

	Controller.LastDanger = {
		Kind = "RedirectApplied",
		Position = rootPart.Position,
	}
end

local function rotateY(vec, degrees)
	local rad = math.rad(degrees)
	local c = math.cos(rad)
	local s = math.sin(rad)

	local rotated = Vector3.new(
		vec.X * c - vec.Z * s,
		0,
		vec.X * s + vec.Z * c
	)

	if rotated.Magnitude <= 0.001 then
		return Vector3.new(0, 0, -1)
	end

	return rotated.Unit
end

local function simulateCandidateSafe(startPos, candidateVel)
	local simulatedPos = startPos
	local simulatedVel = candidateVel
	local elapsed = 0

	while elapsed < CONFIG.SafePathSweepMaxTime do
		local step = math.min(CONFIG.SafePathSweepTimeStep, CONFIG.SafePathSweepMaxTime - elapsed)
		local acc = Vector3.new(0, -Workspace.Gravity, 0) + getDragAcceleration(simulatedVel)

	local nextPos = simulatedPos + simulatedVel * step + 0.5 * acc * step * step
		simulatedVel = simulatedVel + acc * step

		if getAcidNearPoint(nextPos, CONFIG.TrajectoryAcidRadius) then
			return false
		end

		local displacement = nextPos - simulatedPos

		if displacement.Magnitude > 0.001 then
			local ok, hit = pcall(function()
				return Workspace:Spherecast(simulatedPos, CONFIG.CharacterRadius, displacement, raycastParams)
			end)

			if ok and hit then
				if isAcidInstance(hit.Instance) then
					return false
				end

				return true
			end
		end

		simulatedPos = nextPos
		elapsed += step
	end

	return true
end

local function findSafeRedirect(prediction, danger)
	if not prediction or not rootPart then return nil end

	local startPos = rootPart.Position
	local currentVel = rootPart.AssemblyLinearVelocity
	local horizVel = getHorizontal(currentVel)

	local baseDir

	if horizVel.Magnitude > 0.5 then
		baseDir = horizVel.Unit
	else
		baseDir = getNearestAcidDirectionAway(startPos) or safeHorizontalUnit(rootPart.CFrame.LookVector)
	end

	if danger and (
		danger.Kind == "SlideIntoAcid"
		or danger.Kind == "SlideGroundAcid"
		or danger.Kind == "DirectAcidHit"
	) then
		local awayDir = getNearestAcidDirectionAway(startPos)

		if awayDir then
			baseDir += awayDir
			baseDir = baseDir.Magnitude > 0.001 and baseDir.Unit or awayDir
		end
	end

	local horizSpeed = math.clamp(
		math.max(horizVel.Magnitude, CONFIG.RedirectHorizontalSpeed),
		CONFIG.RedirectHorizontalSpeed,
		CONFIG.RedirectMaxHorizontalSpeed
	)

	local liftY = math.max(currentVel.Y, 0) + CONFIG.RedirectLift + CONFIG.ExtraArcLift

	local angles = { 0 }
	local deg = CONFIG.SafePathAngleStep

	while deg <= CONFIG.SafePathMaxAngle do
		table.insert(angles, deg)
		table.insert(angles, -deg)
		deg += CONFIG.SafePathAngleStep
	end

	for _, angle in ipairs(angles) do
		local dir = rotateY(baseDir, angle)
		local candidateVel = dir * horizSpeed + Vector3.new(0, liftY, 0)

		if simulateCandidateSafe(startPos, candidateVel) then
			return candidateVel, angle
		end
	end

	if CONFIG.EmergencyRedirectEnabled then
		local away = getNearestAcidDirectionAway(startPos) or safeHorizontalUnit(rootPart.CFrame.LookVector)
		return away * CONFIG.EmergencyHorizontalSpeed + Vector3.new(0, CONFIG.EmergencyLift, 0), nil
	end

	return nil
end

local function isRedirecting()
	if not Controller.Enabled then
		return false
	end

	if safePathFound then
		local age = os.clock() - safePathFoundAt

		if age <= CONFIG.SafePathCommitWindow then
			return true
		end
	end

	local danger = Controller.LastDanger

	if typeof(danger) == "table" then
		return danger.Kind == "AirPathAcid"
			or danger.Kind == "DirectAcidHit"
			or danger.Kind == "SlideIntoAcid"
			or danger.Kind == "SlideGroundAcid"
			or danger.Kind == "RedirectApplied"
	end

	return false
end

local function runPredictionCycle()
	if not Controller.Enabled or not rootPart or not rootPart.Parent then
		return
	end

local function isRagdolled()
	if not humanoid then return false end

	local state = humanoid:GetState()

	if state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
		or state == Enum.HumanoidStateType.PlatformStanding then
		return true
	end

	if humanoid.PlatformStand then
		return true
	end

	if character then
		local rv = character:FindFirstChild("Ragdolled")
			or character:FindFirstChild("IsRagdolled")
			or character:FindFirstChild("RagdollEnabled")
		if rv and rv:IsA("BoolValue") and rv.Value then
			return true
		end
		if character:GetAttribute("Ragdolled") == true
			or character:GetAttribute("IsRagdolled") == true then
			return true
		end
	end

	return false
end

	local danger = getPredictionAcidDanger(prediction, ragdoll)

	if danger then
		Controller.LastDanger = danger
		Controller.LastAcidPart = danger.Part

		local originalAngular = rootPart.AssemblyAngularVelocity

		notifyThrottled("acid_detected", "Ragdoll trajectory will hit acid; redirecting.")
		drawTrajectoryArc(prediction, danger)

		local candidate, angle = findSafeRedirect(prediction, danger)

		if candidate then
			applyRedirectVelocity(candidate, originalAngular, true)

			if angle then
				notifyThrottled("redirect_applied", string.format("Ragdoll redirect applied (%d deg).", angle))
			else
				notifyThrottled("redirect_applied", "Emergency ragdoll redirect applied.")
			end
		end
	else
		if not isRedirecting() then
			Controller.LastDanger = nil
			Controller.LastAcidPart = nil
		end

		if CONFIG.ShowTrajectoryArc then
			drawTrajectoryArc(prediction, nil)
		elseif CONFIG.ClearArcWhenIdle then
			clearTrajectoryArc()
		end
	end
end

local function onHeartbeat(dt)
	if not Controller.Enabled then return end
	if not rootPart or not rootPart.Parent then return end

	if safePathFound then
		local age = os.clock() - safePathFoundAt

		if age <= CONFIG.SafePathCommitWindow then
			if (safePathVelocity - rootPart.AssemblyLinearVelocity).Magnitude > 1.5 then
				task.spawn(function()
					pushVelocity(safePathVelocity, safePathAngularVelocity, false, safePathHasSpin)
				end)
			end
		else
			safePathFound = false
			safePathFoundAt = 0
			safePathVelocity = Vector3.zero
			safePathAngularVelocity = Vector3.zero
			safePathHasSpin = false

			if CONFIG.ClearArcWhenIdle then
				clearTrajectoryArc()
			end
		end
	end

	accumulatedPredict += dt

	if accumulatedPredict >= CONFIG.PredictEvery then
		accumulatedPredict = 0

		task.spawn(function()
			local ok, err = pcall(runPredictionCycle)

			if not ok then
				Controller.LastError = tostring(err)
			end
		end)
	end
end

local function connectHeartbeat()
	if not heartbeatConn then
		heartbeatConn = RunService.Heartbeat:Connect(onHeartbeat)
	end
end

local function disconnectHeartbeat()
	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end
end

local function onCharacterAdded(char)
	setupCharacter(char)

	if Controller.Running then
		connectHeartbeat()
	end
end

local function onCharacterRemoving()
	setupCharacter(nil)
end

if LocalPlayer then
	if LocalPlayer.Character then
		setupCharacter(LocalPlayer.Character)
	end

	charAddedConn = LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
	charRemovingConn = LocalPlayer.CharacterRemoving:Connect(onCharacterRemoving)
end

rebuildAcidParts()

Controller.Start = function()
	Controller.Enabled = true
	Controller.Running = true
	connectHeartbeat()
end

Controller.Stop = function()
	Controller.Running = false
	Controller.Enabled = false

	disconnectHeartbeat()

	safePathFound = false
	safePathFoundAt = 0
	safePathVelocity = Vector3.zero
	safePathAngularVelocity = Vector3.zero
	safePathHasSpin = false

	Controller.LastDanger = nil
	Controller.LastAcidPart = nil

	clearTrajectoryArc()
end

Controller.Destroy = function()
	Controller.Stop()

	if charAddedConn then
		charAddedConn:Disconnect()
		charAddedConn = nil
	end

	if charRemovingConn then
		charRemovingConn:Disconnect()
		charRemovingConn = nil
	end

	if global.__AcidRedirectController == Controller then
		global.__AcidRedirectController = nil
	end
end

Controller.HideArc = function()
	clearTrajectoryArc()
end

Controller.ClearArc = function()
	clearTrajectoryArc()
end

Controller.SetPredictor = function(predictor)
	if typeof(predictor) == "function" then
		ExternalPredictPlayerLanding = predictor
		Controller.UsingExternalTrajectoryApi = true
	end
end

Controller.IsRedirecting = function()
	return isRedirecting()
end

Controller.Enable = function(val)
	Controller.Enabled = (val == nil) and true or (val == true)
end

Controller.RebuildAcidCache = function()
	rebuildAcidParts()
end

Controller.SetConfig = function(newConfig)
	if typeof(newConfig) ~= "table" then return end

	for k, v in pairs(newConfig) do
		CONFIG[k] = v
	end

	applyConfigAliases()
end

Controller.GetState = function()
	return {
		Controller = Controller,
		Config = CONFIG,
		Character = character,
		RootPart = rootPart,
		Ragdolled = isRagdolled(),
		Redirecting = isRedirecting(),
		RequireTrajectoryApi = CONFIG.RequireTrajectoryApi,
		RedirectOnlyWhenRagdolled = CONFIG.RedirectOnlyWhenRagdolled,
	}
end

Controller.ForcePredict = function()
	task.spawn(function()
		local ok, err = pcall(runPredictionCycle)

		if not ok then
			Controller.LastError = tostring(err)
		end
	end)
end

Controller.ForceRedirect = function(velocity, angularVelocity)
	if typeof(velocity) ~= "Vector3" then return end

	local ragdoll = isRagdolled()

	if CONFIG.RedirectOnlyWhenRagdolled and not ragdoll then
		return
	end

	applyRedirectVelocity(velocity, angularVelocity or rootPart.AssemblyAngularVelocity, ragdoll)
end

Controller.Start()
global.__AcidRedirectController = Controller

return Controller
