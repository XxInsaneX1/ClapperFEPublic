local function clearArray(array)
	for i = #array, 1, -1 do
		array[i] = nil
	end
end

local function disconnectAll(array)
	for _, c in ipairs(array) do
		pcall(function()
			c:Disconnect()
		end)
	end
	clearArray(array)
end

local function notify(message, duration)
	if not NotifyCallback then
		return
	end

	pcall(function()
		NotifyCallback("Acid-Redirect", message, duration or 2.5)
	end)
end

local function notifyThrottled(key, message, duration)
	if CONFIG.EnableNotifications == false then
		return
	end

	local now = os.clock()
	local last = notifyTimes[key]

	if last and now - last < CONFIG.NotificationCooldown then
		return
	end

	notifyTimes[key] = now
	notify(message, duration)
end

local function getRootPart(model)
	if not model then
		return nil
	end

	return model:FindFirstChild("HumanoidRootPart")
		or model:FindFirstChild("Torso")
		or model:FindFirstChild("UpperTorso")
end

local function updateRaycastParams()
	local exclude = character and { character } or {}

	raycastParams.FilterDescendantsInstances = exclude
	broadHazardOverlapParams.FilterDescendantsInstances = exclude
end

local function setupCharacter(nextCharacter)
	character = nextCharacter

	if not nextCharacter then
		humanoid = nil
		rootPart = nil
		updateRaycastParams()
		return
	end

	humanoid = nextCharacter:FindFirstChildOfClass("Humanoid")
	rootPart = getRootPart(nextCharacter)

	if not humanoid then
		task.spawn(function()
			local found = nextCharacter:WaitForChild("Humanoid", 8)
			if character == nextCharacter and found then
				humanoid = found
			end
		end)
	end

	if not rootPart then
		task.spawn(function()
			local found = nextCharacter:WaitForChild("HumanoidRootPart", 8)
			if character == nextCharacter and found then
				rootPart = found
			end
		end)
	end

	updateRaycastParams()
end

local function isRagdolled()
	if not humanoid or not humanoid.Parent then
		return false
	end

	local state = humanoid:GetState()

	return state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
end

