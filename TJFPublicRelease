--------------------------------------------------------------------------
-- Trajectory Finder API v2 fixed
-- Returns PredictPlayerLanding(playerObjectOrCharacter, options)
--------------------------------------------------------------------------

local Workspace = game:GetService("Workspace")

local SHOW_TRAJECTORY_ARC = true
local ARC_FOLDER_NAME = "__TrajectoryArcVisuals"

local DEFAULT_OPTIONS = {
	MaxTime = 5,
	TimeStep = 1 / 60,
	Gravity = Workspace.Gravity,

	AirDensity = 0.02,
	DragCoefficient = 0.7,
	CrossSectionArea = 1.2,

	MagnusCoefficient = 0.006,
	MaxMagnusAcceleration = 80,

	CastMode = "Block",
	CastPadding = 0.05,
	IgnoreWater = true,
	IgnoreInstances = nil,

	Mass = nil,
	CastSize = nil,
	CastRadius = nil,

	DrawArc = nil,
	ClearArc = true,
	ArcVisualStride = 1,
	ArcThickness = 0.12,
	ArcTransparency = 0.08,

	RagdollExtraPath = true,
	RagdollMaxVisualPaths = 2,
	RagdollSideVelocity = 18,
	RagdollForwardBlend = 0.35,
}

local ARC_PRIMARY_COLOR = Color3.fromRGB(0, 255, 180)
local ARC_SECONDARY_COLOR = Color3.fromRGB(255, 190, 60)
local ARC_HIT_COLOR = Color3.fromRGB(255, 70, 70)
local ARC_END_MARKER_COLOR = Color3.fromRGB(255, 0, 0)

local function isPositiveNumber(v)
	return typeof(v) == "number" and v > 0
end

local function mergeOptions(options)
	local merged = {}

	for k, v in pairs(DEFAULT_OPTIONS) do
		merged[k] = v
	end

	if typeof(options) == "table" then
		for k, v in pairs(options) do
			merged[k] = v
		end
	end

	if not isPositiveNumber(merged.MaxTime) then
		merged.MaxTime = DEFAULT_OPTIONS.MaxTime
	end

	if not isPositiveNumber(merged.TimeStep) then
		merged.TimeStep = DEFAULT_OPTIONS.TimeStep
	end

	merged.TimeStep = math.clamp(merged.TimeStep, 1 / 240, 1 / 10)

	if typeof(merged.Gravity) ~= "number" or merged.Gravity < 0 then
		merged.Gravity = DEFAULT_OPTIONS.Gravity
	end

	if typeof(merged.IgnoreWater) ~= "boolean" then
		merged.IgnoreWater = DEFAULT_OPTIONS.IgnoreWater
	end

	return merged
end

local function getCharacter(playerOrCharacter)
	if typeof(playerOrCharacter) ~= "Instance" then
		return nil
	end

	if playerOrCharacter:IsA("Player") then
		return playerOrCharacter.Character
	end

	if playerOrCharacter:IsA("Model") then
		return playerOrCharacter
	end

	return nil
end

local function getRootPart(character)
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
		or character:FindFirstChild("Torso")
		or character:FindFirstChild("UpperTorso")
end

local function getHumanoid(character)
	return character and character:FindFirstChildOfClass("Humanoid") or nil
end

local function isRagdollState(state)
	return state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
end

local function isCharacterRagdolled(character)
	local humanoid = getHumanoid(character)
	return humanoid and isRagdollState(humanoid:GetState()) or false
end

local function getMass(rootPart, character, options)
	if isPositiveNumber(options.Mass) then
		return options.Mass
	end

	if rootPart and rootPart:IsA("BasePart") and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end

	local totalMass = 0

	if character then
		for _, d in ipairs(character:GetDescendants()) do
			if d:IsA("BasePart") then
				totalMass += d:GetMass()
			end
		end
	end

	return totalMass > 0 and totalMass or 70
end

local function buildRaycastParams(character, options)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = options.IgnoreWater

	local ignore = {}

	if character then
		table.insert(ignore, character)
	end

	if typeof(options.IgnoreInstances) == "table" then
		for _, inst in ipairs(options.IgnoreInstances) do
			if typeof(inst) == "Instance" then
				table.insert(ignore, inst)
			end
		end
	end

	params.FilterDescendantsInstances = ignore
	return params
end

local function getCastInfo(rootPart, character, options)
	local mode = options.CastMode
	if mode ~= "Block" and mode ~= "Sphere" and mode ~= "Ray" then
		mode = DEFAULT_OPTIONS.CastMode
	end

	local rotation = rootPart.CFrame.Rotation
	local centerOffset = Vector3.zero
	local size = rootPart.Size

	if typeof(options.CastSize) == "Vector3" then
		size = options.CastSize
	elseif character then
		local boundsCFrame, boundsSize = character:GetBoundingBox()
		centerOffset = rootPart.CFrame:PointToObjectSpace(boundsCFrame.Position)
		size = boundsSize
	end

	local padding = isPositiveNumber(options.CastPadding) and options.CastPadding or 0
	size = Vector3.new(
		math.max(size.X - padding, 0.1),
		math.max(size.Y - padding, 0.1),
		math.max(size.Z - padding, 0.1)
	)

	local radius = isPositiveNumber(options.CastRadius) and options.CastRadius or math.max(size.X, size.Z) * 0.5

	return {
		Mode = mode,
		Rotation = rotation,
		CenterOffset = centerOffset,
		Size = size,
		Radius = math.max(radius, 0.1),
	}
end

local function getDragAcceleration(velocity, mass, options)
	local speed = velocity.Magnitude

	if speed <= 0.001 then
		return Vector3.zero
	end

	local airDensity = typeof(options.AirDensity) == "number" and options.AirDensity or DEFAULT_OPTIONS.AirDensity
	local dragCoefficient = typeof(options.DragCoefficient) == "number" and options.DragCoefficient or DEFAULT_OPTIONS.DragCoefficient
	local crossSectionArea = typeof(options.CrossSectionArea) == "number" and options.CrossSectionArea or DEFAULT_OPTIONS.CrossSectionArea

	if airDensity <= 0 or dragCoefficient <= 0 or crossSectionArea <= 0 then
		return Vector3.zero
	end

	local dragMagnitude = 0.5 * airDensity * dragCoefficient * crossSectionArea * speed * speed
	return -velocity.Unit * (dragMagnitude / mass)
end

local function getMagnusAcceleration(velocity, angularVelocity, options)
	if velocity.Magnitude <= 0.001 or angularVelocity.Magnitude <= 0.001 then
		return Vector3.zero
	end

	local coefficient = typeof(options.MagnusCoefficient) == "number" and options.MagnusCoefficient or DEFAULT_OPTIONS.MagnusCoefficient
	if coefficient <= 0 then
		return Vector3.zero
	end

	local magnus = angularVelocity:Cross(velocity) * coefficient
	local maxAcceleration = isPositiveNumber(options.MaxMagnusAcceleration) and options.MaxMagnusAcceleration or DEFAULT_OPTIONS.MaxMagnusAcceleration

	if magnus.Magnitude > maxAcceleration then
		magnus = magnus.Unit * maxAcceleration
	end

	return magnus
end

local function safeSpherecast(position, radius, displacement, params)
	local ok, result = pcall(function()
		return Workspace:Spherecast(position, radius, displacement, params)
	end)

	if ok then
		return result
	end

	return Workspace:Raycast(position, displacement, params)
end

local function safeBlockcast(cframe, size, displacement, params)
	local ok, result = pcall(function()
		return Workspace:Blockcast(cframe, size, displacement, params)
	end)

	if ok then
		return result
	end

	return Workspace:Raycast(cframe.Position, displacement, params)
end

local function castAlongPath(position, displacement, castInfo, params)
	if displacement.Magnitude <= 0.001 then
		return nil
	end

	if castInfo.Mode == "Ray" then
		return Workspace:Raycast(position, displacement, params)
	end

	if castInfo.Mode == "Sphere" then
		return safeSpherecast(position, castInfo.Radius, displacement, params)
	end

	local castCenter = position + castInfo.Rotation:VectorToWorldSpace(castInfo.CenterOffset)
	local castCFrame = CFrame.new(castCenter) * castInfo.Rotation

	return safeBlockcast(castCFrame, castInfo.Size, displacement, params)
end

local function getArcFolder()
	local folder = Workspace:FindFirstChild(ARC_FOLDER_NAME)

	if not folder then
		folder = Instance.new("Folder")
		folder.Name = ARC_FOLDER_NAME
		folder.Parent = Workspace
	end

	return folder
end

local function clearArcFolder()
	local folder = Workspace:FindFirstChild(ARC_FOLDER_NAME)
	if folder then
		folder:ClearAllChildren()
	end
end

local function makeArcPart(name, size, color, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.Neon
	part.Color = color
	part.Transparency = transparency
	part.Size = size
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function getCylinderCFrameBetween(a, b)
	local midpoint = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawSolidPath(prediction, color, options, prefix)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then
		return
	end

	local trajectory = prediction.Trajectory
	if #trajectory <= 0 then
		return
	end

	local folder = getArcFolder()
	local stride = math.max(math.floor(isPositiveNumber(options.ArcVisualStride) and options.ArcVisualStride or 1), 1)
	local thickness = isPositiveNumber(options.ArcThickness) and options.ArcThickness or 0.12
	local transparency = typeof(options.ArcTransparency) == "number" and options.ArcTransparency or 0.08

	for i = 1, #trajectory - 1, stride do
		local a = trajectory[i]
		local b = trajectory[math.min(i + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local segment = makeArcPart(prefix .. "_Path", Vector3.new(thickness, distance, thickness), color, transparency)
				segment.Shape = Enum.PartType.Cylinder
				segment.CFrame = getCylinderCFrameBetween(a, b)
				segment.Parent = folder
			end
		end
	end
end

local function drawEndMarker(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" or #prediction.Trajectory <= 0 then
		return
	end

	local markerPosition = prediction.LandPosition or prediction.RootPosition or prediction.Trajectory[#prediction.Trajectory]
	if typeof(markerPosition) ~= "Vector3" then
		return
	end

	local marker = makeArcPart("EndMarker", Vector3.new(0.85, 0.85, 0.85), ARC_END_MARKER_COLOR, 0.02)
	marker.Shape = Enum.PartType.Ball
	marker.CFrame = CFrame.new(markerPosition)
	marker.Parent = getArcFolder()
end

local function buildPredictionFromState(character, rootPart, options, initialVelocity, initialAngularVelocity)
	local mass = getMass(rootPart, character, options)
	local position = rootPart.Position
	local velocity = initialVelocity or rootPart.AssemblyLinearVelocity
	local angularVelocity = initialAngularVelocity or rootPart.AssemblyAngularVelocity
	local gravity = Vector3.new(0, -options.Gravity, 0)
	local params = buildRaycastParams(character, options)
	local castInfo = getCastInfo(rootPart, character, options)
	local trajectory = { position }

	local elapsed = 0

	while elapsed < options.MaxTime do
		local step = math.min(options.TimeStep, options.MaxTime - elapsed)
		local acceleration = gravity + getDragAcceleration(velocity, mass, options) + getMagnusAcceleration(velocity, angularVelocity, options)
		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position
		local hitResult = castAlongPath(position, displacement, castInfo, params)

		if hitResult then
			local alpha = math.clamp(hitResult.Distance / math.max(displacement.Magnitude, 0.001), 0, 1)
			local hitRootPosition = position:Lerp(nextPosition, alpha)
			local hitTime = elapsed + step * alpha

			table.insert(trajectory, hitRootPosition)

			return {
				Trajectory = trajectory,
				HitResult = hitResult,
				HitPart = hitResult.Instance,
				LandPosition = hitResult.Position,
				RootPosition = hitRootPosition,
				LandNormal = hitResult.Normal,
				Time = hitTime,
				Velocity = velocity:Lerp(nextVelocity, alpha),
				CastMode = castInfo.Mode,
				CastSize = castInfo.Size,
				CastRadius = castInfo.Radius,
				Reason = "Hit",
			}
		end

		position = nextPosition
		velocity = nextVelocity
		elapsed += step

		table.insert(trajectory, position)
	end

	return {
		Trajectory = trajectory,
		HitResult = nil,
		HitPart = nil,
		LandPosition = trajectory[#trajectory],
		RootPosition = trajectory[#trajectory],
		Time = options.MaxTime,
		Velocity = velocity,
		CastMode = castInfo.Mode,
		CastSize = castInfo.Size,
		CastRadius = castInfo.Radius,
		Reason = "No hit within MaxTime",
	}
end

local function getHorizontal(v)
	return Vector3.new(v.X, 0, v.Z)
end

local function getRagdollAlternateVelocity(rootPart, options)
	local velocity = rootPart.AssemblyLinearVelocity
	local horizontal = getHorizontal(velocity)
	local look = getHorizontal(rootPart.CFrame.LookVector)

	local baseDirection

	if horizontal.Magnitude > 0.001 then
		baseDirection = horizontal.Unit
	elseif look.Magnitude > 0.001 then
		baseDirection = look.Unit
	else
		baseDirection = Vector3.new(1, 0, 0)
	end

	local side = Vector3.new(-baseDirection.Z, 0, baseDirection.X).Unit

	if rootPart.AssemblyAngularVelocity.Y < 0 then
		side = -side
	end

	local sideVelocity = isPositiveNumber(options.RagdollSideVelocity) and options.RagdollSideVelocity or 18
	local forwardBlend = typeof(options.RagdollForwardBlend) == "number" and options.RagdollForwardBlend or 0.35
	forwardBlend = math.clamp(forwardBlend, 0, 1)

	local alternateHorizontal = horizontal * forwardBlend + side * sideVelocity
	return Vector3.new(alternateHorizontal.X, velocity.Y, alternateHorizontal.Z)
end

local function shouldDrawArc(options)
	if options.DrawArc == false then
		return false
	end

	if options.DrawArc == true then
		return true
	end

	return SHOW_TRAJECTORY_ARC
end

local function drawPredictionVisuals(character, rootPart, options, prediction)
	if not shouldDrawArc(options) then
		return
	end

	if options.ClearArc ~= false then
		clearArcFolder()
	end

	drawSolidPath(prediction, prediction.HitPart and ARC_HIT_COLOR or ARC_PRIMARY_COLOR, options, "Primary")
	drawEndMarker(prediction)

	if not isCharacterRagdolled(character) then
		return
	end

	if options.RagdollExtraPath == false then
		return
	end

	local maxPaths = math.clamp(math.floor(isPositiveNumber(options.RagdollMaxVisualPaths) and options.RagdollMaxVisualPaths or 2), 1, 2)
	if maxPaths < 2 then
		return
	end

	local alternateVelocity = getRagdollAlternateVelocity(rootPart, options)
	if (alternateVelocity - rootPart.AssemblyLinearVelocity).Magnitude <= 0.5 then
		return
	end

	local alternatePrediction = buildPredictionFromState(character, rootPart, options, alternateVelocity, rootPart.AssemblyAngularVelocity)
	drawSolidPath(alternatePrediction, alternatePrediction.HitPart and ARC_HIT_COLOR or ARC_SECONDARY_COLOR, options, "RagdollAlt")
end

local function returnPrediction(prediction)
	return prediction.Trajectory, prediction.HitPart, prediction.HitResult, prediction
end

local function PredictPlayerLanding(playerOrCharacter, options)
	options = mergeOptions(options)

	local character = getCharacter(playerOrCharacter)
	local rootPart = getRootPart(character)

	if not rootPart or not rootPart:IsA("BasePart") then
		return returnPrediction({
			Trajectory = {},
			HitResult = nil,
			HitPart = nil,
			Reason = "No HumanoidRootPart/Torso found",
			DrawArc = options.DrawArc,
		})
	end

	local prediction = buildPredictionFromState(
		character,
		rootPart,
		options,
		rootPart.AssemblyLinearVelocity,
		rootPart.AssemblyAngularVelocity
	)

	prediction.DrawArc = options.DrawArc
	prediction.Ragdolled = isCharacterRagdolled(character)

	drawPredictionVisuals(character, rootPart, options, prediction)

	return returnPrediction(prediction)
end

return PredictPlayerLanding
