-- Trajectory Finder API v2
-- Solid path tracer + ragdoll-aware 1-2 path visualization.
--
-- Returns PredictPlayerLanding(playerObjectOrCharacter, options)
--
-- Usage:
-- local PredictPlayerLanding = loadstring(game:HttpGet(URL))()
-- local trajectory, hitPart, hitResult, data = PredictPlayerLanding(Players.LocalPlayer, options)

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

--------------------------------------------------------------------------
-- TOP-LEVEL VISUAL TOGGLES
--------------------------------------------------------------------------

local SHOW_TRAJECTORY_ARC = true

-- Solid line tracer, no dotted path.
local ARC_FOLDER_NAME = "__TrajectoryArcVisuals"
local ARC_CLEAR_EACH_PREDICTION = true

local ARC_PRIMARY_COLOR = Color3.fromRGB(0, 255, 180)
local ARC_SECONDARY_COLOR = Color3.fromRGB(255, 190, 60)
local ARC_HIT_COLOR = Color3.fromRGB(255, 70, 70)
local ARC_END_MARKER_COLOR = Color3.fromRGB(255, 0, 0)

local ARC_THICKNESS = 0.12
local ARC_TRANSPARENCY = 0.08
local ARC_MATERIAL = Enum.Material.Neon
local ARC_END_MARKER_SIZE = 0.85

-- 1 = smoothest connected line.
-- 2/3 = fewer parts, better performance.
local ARC_VISUAL_STRIDE = 1

-- Ragdoll visual behavior:
-- When ragdolled, draw only 1 or 2 plausible solid paths.
local RAGDOLL_DRAW_EXTRA_PATH = true
local RAGDOLL_MAX_VISUAL_PATHS = 2
local RAGDOLL_SIDE_VELOCITY = 18
local RAGDOLL_FORWARD_BLEND = 0.35

--------------------------------------------------------------------------

local DEFAULT_OPTIONS = {
	MaxTime = 5,
	TimeStep = 1 / 60,
	Gravity = Workspace.Gravity,

	-- Roblox-stud tuned values, not real-world SI constants.
	AirDensity = 0.02,
	DragCoefficient = 0.7,
	CrossSectionArea = 1.2,

	MagnusCoefficient = 0.006,
	MaxMagnusAcceleration = 80,

	-- "Block" is best for normal characters.
	-- "Sphere" is often better for ragdoll/acid redirect checks.
	CastMode = "Block",
	CastPadding = 0.05,
	IgnoreWater = true,
	IgnoreInstances = nil,

	Mass = nil,
	CastSize = nil,
	CastRadius = nil,

	-- Visual options.
	DrawArc = nil,
	ClearArc = nil,
	ArcVisualStride = nil,
	ArcThickness = nil,
	ArcTransparency = nil,

	-- Ragdoll visual options.
	RagdollExtraPath = nil,
	RagdollMaxVisualPaths = nil,
	RagdollSideVelocity = nil,
	RagdollForwardBlend = nil,
}

local function isPositiveNumber(value)
	return typeof(value) == "number" and value > 0
end

local function mergeOptions(options)
	local merged = {}

	for key, value in pairs(DEFAULT_OPTIONS) do
		merged[key] = value
	end

	if typeof(options) == "table" then
		for key, value in pairs(options) do
			merged[key] = value
		end
	end

	if not isPositiveNumber(merged.MaxTime) then
		merged.MaxTime = DEFAULT_OPTIONS.MaxTime
	end

	if not isPositiveNumber(merged.TimeStep) then
		merged.TimeStep = DEFAULT_OPTIONS.TimeStep
	end

	merged.TimeStep = math.clamp(merged.TimeStep, 1 / 240, 1 / 10)

	if typeof(merged.Gravity) ~= "number" or merged.Gravity < 0 then
		merged.Gravity = DEFAULT_OPTIONS.Gravity
	end

	if typeof(merged.IgnoreWater) ~= "boolean" then
		merged.IgnoreWater = DEFAULT_OPTIONS.IgnoreWater
	end

	return merged
end

local function getCharacterFromPlayerOrCharacter(playerOrCharacter)
	if typeof(playerOrCharacter) ~= "Instance" then
		return nil
	end

	if playerOrCharacter:IsA("Player") then
		return playerOrCharacter.Character
	end

	if playerOrCharacter:IsA("Model") then
		return playerOrCharacter
	end

	return nil
end

local function getRootPart(character)
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
		or character:FindFirstChild("Torso")
		or character:FindFirstChild("UpperTorso")
end

local function getHumanoid(character)
	if not character then
		return nil
	end

	return character:FindFirstChildOfClass("Humanoid")
end

local function isRagdollState(state)
	return state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
end

local function isCharacterRagdolled(character)
	local humanoid = getHumanoid(character)

	if not humanoid then
		return false
	end

	return isRagdollState(humanoid:GetState())
end

local function getMass(rootPart, character, options)
	if isPositiveNumber(options.Mass) then
		return options.Mass
	end

	if rootPart and rootPart:IsA("BasePart") and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end

	if character then
		local totalMass = 0

		for _, descendant in ipairs(character:GetDescendants()) do
			if descendant:IsA("BasePart") then
				totalMass += descendant:GetMass()
			end
		end

		if totalMass > 0 then
			return totalMass
		end
	end

	return 70
end

local function buildRaycastParams(character, options)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.IgnoreWater = options.IgnoreWater

	local ignore = {}

	if character then
		table.insert(ignore, character)
	end

	if typeof(options.IgnoreInstances) == "table" then
		for _, instance in ipairs(options.IgnoreInstances) do
			if typeof(instance) == "Instance" then
				table.insert(ignore, instance)
			end
		end
	end

	raycastParams.FilterDescendantsInstances = ignore
	return raycastParams
end

local function getCastInfo(rootPart, character, options)
	local rotation = rootPart.CFrame.Rotation
	local centerOffset = Vector3.zero
	local size = rootPart.Size
	local castMode = options.CastMode

	if castMode ~= "Block" and castMode ~= "Sphere" and castMode ~= "Ray" then
		castMode = DEFAULT_OPTIONS.CastMode
	end

	if typeof(options.CastSize) == "Vector3" then
		size = options.CastSize
	elseif character then
		local boundsCFrame, boundsSize = character:GetBoundingBox()
		centerOffset = rootPart.CFrame:PointToObjectSpace(boundsCFrame.Position)
		size = boundsSize
	end

	local padding = if isPositiveNumber(options.CastPadding) then options.CastPadding else 0

	size = Vector3.new(
		math.max(size.X - padding, 0.1),
		math.max(size.Y - padding, 0.1),
		math.max(size.Z - padding, 0.1)
	)

	local radius = options.CastRadius

	if not isPositiveNumber(radius) then
		radius = math.max(size.X, size.Z) * 0.5
	end

	return {
		Mode = castMode,
		Rotation = rotation,
		CenterOffset = centerOffset,
		Size = size,
		Radius = math.max(radius, 0.1),
	}
end

local function getDragAcceleration(velocity, mass, options)
	local speed = velocity.Magnitude

	if speed <= 0.001 then
		return Vector3.zero
	end

	local airDensity = if typeof(options.AirDensity) == "number" then options.AirDensity else DEFAULT_OPTIONS.AirDensity
	local dragCoefficient = if typeof(options.DragCoefficient) == "number" then options.DragCoefficient else DEFAULT_OPTIONS.DragCoefficient
	local crossSectionArea = if typeof(options.CrossSectionArea) == "number" then options.CrossSectionArea else DEFAULT_OPTIONS.CrossSectionArea

	if airDensity <= 0 or dragCoefficient <= 0 or crossSectionArea <= 0 then
		return Vector3.zero
	end

	local dragMagnitude = 0.5 * airDensity * dragCoefficient * crossSectionArea * speed * speed
	return -velocity.Unit * (dragMagnitude / mass)
end

local function getMagnusAcceleration(velocity, angularVelocity, options)
	if velocity.Magnitude <= 0.001 or angularVelocity.Magnitude <= 0.001 then
		return Vector3.zero
	end

	local coefficient = if typeof(options.MagnusCoefficient) == "number" then options.MagnusCoefficient else DEFAULT_OPTIONS.MagnusCoefficient

	if coefficient <= 0 then
		return Vector3.zero
	end

	local magnus = angularVelocity:Cross(velocity) * coefficient
	local maxAcceleration = if isPositiveNumber(options.MaxMagnusAcceleration) then options.MaxMagnusAcceleration else DEFAULT_OPTIONS.MaxMagnusAcceleration

	if magnus.Magnitude > maxAcceleration then
		magnus = magnus.Unit * maxAcceleration
	end

	return magnus
end

local function castAlongPath(position, displacement, castInfo, raycastParams)
	if displacement.Magnitude <= 0 then
		return nil
	end

	if castInfo.Mode == "Ray" then
		return Workspace:Raycast(position, displacement, raycastParams)
	end

	if castInfo.Mode == "Sphere" then
		return Workspace:Spherecast(position, castInfo.Radius, displacement, raycastParams)
	end

	local castCenter = position + castInfo.Rotation:VectorToWorldSpace(castInfo.CenterOffset)
	local castCFrame = CFrame.new(castCenter) * castInfo.Rotation

	return Workspace:Blockcast(castCFrame, castInfo.Size, displacement, raycastParams)
end

--------------------------------------------------------------------------
-- Solid arc drawing
--------------------------------------------------------------------------

local function getArcFolder()
	local folder = Workspace:FindFirstChild(ARC_FOLDER_NAME)

	if not folder then
		folder = Instance.new("Folder")
		folder.Name = ARC_FOLDER_NAME
		folder.Parent = Workspace
	end

	return folder
end

local function clearArcFolder()
	local folder = Workspace:FindFirstChild(ARC_FOLDER_NAME)

	if not folder then
		return
	end

	for _, child in ipairs(folder:GetChildren()) do
		child:Destroy()
	end
end

local function makeArcPart(name, size, color, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = ARC_MATERIAL
	part.Color = color
	part.Transparency = transparency
	part.Size = size
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth

	return part
end

local function getCylinderCFrameBetween(a, b)
	local midpoint = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawSolidPath(prediction, color, options, namePrefix)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then
		return
	end

	local trajectory = prediction.Trajectory

	if #trajectory <= 0 then
		return
	end

	local folder = getArcFolder()

	local stride = if isPositiveNumber(options.ArcVisualStride) then options.ArcVisualStride else ARC_VISUAL_STRIDE
	stride = math.max(math.floor(stride), 1)

	local thickness = if isPositiveNumber(options.ArcThickness) then options.ArcThickness else ARC_THICKNESS
	local transparency = if typeof(options.ArcTransparency) == "number" then options.ArcTransparency else ARC_TRANSPARENCY

	for index = 1, #trajectory - 1, stride do
		local a = trajectory[index]
		local b = trajectory[math.min(index + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local segment = makeArcPart(
					namePrefix .. "_SolidPath",
					Vector3.new(thickness, distance, thickness),
					color,
					transparency
				)

				segment.Shape = Enum.PartType.Cylinder
				segment.CFrame = getCylinderCFrameBetween(a, b)
				segment.Parent = folder
			end
		end
	end
end

local function drawEndMarker(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then
		return
	end

	local trajectory = prediction.Trajectory

	if #trajectory <= 0 then
		return
	end

	local markerPosition = prediction.LandPosition or prediction.RootPosition or trajectory[#trajectory]

	if typeof(markerPosition) ~= "Vector3" then
		return
	end

	local marker = makeArcPart(
		"EndMarker",
		Vector3.new(ARC_END_MARKER_SIZE, ARC_END_MARKER_SIZE, ARC_END_MARKER_SIZE),
		ARC_END_MARKER_COLOR,
		0.02
	)

	marker.Shape = Enum.PartType.Ball
	marker.CFrame = CFrame.new(markerPosition)
	marker.Parent = getArcFolder()
end

--------------------------------------------------------------------------
-- Prediction core
--------------------------------------------------------------------------

local function buildPredictionFromState(character, rootPart, options, initialVelocity, initialAngularVelocity)
	local mass = getMass(rootPart, character, options)
	local position = rootPart.Position
	local velocity = initialVelocity or rootPart.AssemblyLinearVelocity
	local angularVelocity = initialAngularVelocity or rootPart.AssemblyAngularVelocity
	local gravity = Vector3.new(0, -options.Gravity, 0)
	local raycastParams = buildRaycastParams(character, options)
	local castInfo = getCastInfo(rootPart, character, options)
	local trajectory = { position }

	local elapsed = 0

	while elapsed < options.MaxTime do
		local step = math.min(options.TimeStep, options.MaxTime - elapsed)
		local dragAcceleration = getDragAcceleration(velocity, mass, options)
		local magnusAcceleration = getMagnusAcceleration(velocity, angularVelocity, options)
		local acceleration = gravity + dragAcceleration + magnusAcceleration

		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position
		local hitResult = castAlongPath(position, displacement, castInfo, raycastParams)

		if hitResult then
			local alpha = math.clamp(hitResult.Distance / math.max(displacement.Magnitude, 0.001), 0, 1)
			local hitRootPosition = position:Lerp(nextPosition, alpha)
			local hitTime = elapsed + step * alpha

			table.insert(trajectory, hitRootPosition)

			return {
				Trajectory = trajectory,
				HitResult = hitResult,
				HitPart = hitResult.Instance,
				LandPosition = hitResult.Position,
				RootPosition = hitRootPosition,
				LandNormal = hitResult.Normal,
				Time = hitTime,
				Velocity = velocity:Lerp(nextVelocity, alpha),
				CastMode = castInfo.Mode,
				CastSize = castInfo.Size,
				CastRadius = castInfo.Radius,
				Reason = "Hit",
			}
		end

		position = nextPosition
		velocity = nextVelocity
		elapsed += step

		table.insert(trajectory, position)
	end

	return {
		Trajectory = trajectory,
		HitResult = nil,
		HitPart = nil,
		LandPosition = trajectory[#trajectory],
		RootPosition = trajectory[#trajectory],
		Time = options.MaxTime,
		Velocity = velocity,
		CastMode = castInfo.Mode,
		CastSize = castInfo.Size,
		CastRadius = castInfo.Radius,
		Reason = "No hit within MaxTime",
	}
end

local function getHorizontal(vector)
	return Vector3.new(vector.X, 0, vector.Z)
end

local function getRagdollAlternateVelocity(rootPart, options)
	local velocity = rootPart.AssemblyLinearVelocity
	local horizontal = getHorizontal(velocity)
	local look = getHorizontal(rootPart.CFrame.LookVector)

	local baseDirection

	if horizontal.Magnitude > 0.001 then
		baseDirection = horizontal.Unit
	elseif look.Magnitude > 0.001 then
		baseDirection = look.Unit
	else
		baseDirection = Vector3.new(1, 0, 0)
	end

	local side = Vector3.new(-baseDirection.Z, 0, baseDirection.X)

	if side.Magnitude <= 0.001 then
		side = Vector3.new(1, 0, 0)
	end

	side = side.Unit

	local angular = rootPart.AssemblyAngularVelocity

	-- Pick ONE most likely alternate side based on spin.
	-- This prevents messy fan/spaghetti tracers.
	if angular.Y < 0 then
		side = -side
	end

	local sideVelocity = if isPositiveNumber(options.RagdollSideVelocity) then options.RagdollSideVelocity else RAGDOLL_SIDE_VELOCITY
	local forwardBlend = if typeof(options.RagdollForwardBlend) == "number" then options.RagdollForwardBlend else RAGDOLL_FORWARD_BLEND
	forwardBlend = math.clamp(forwardBlend, 0, 1)

	local alternateHorizontal = horizontal * forwardBlend + side * sideVelocity
	return Vector3.new(alternateHorizontal.X, velocity.Y, alternateHorizontal.Z)
end

local function shouldDrawArc(options)
	if options.DrawArc == false then
		return false
	end

	if options.DrawArc == true then
		return true
	end

	return SHOW_TRAJECTORY_ARC
end

local function drawPredictionVisuals(character, rootPart, options, primaryPrediction)
	if not shouldDrawArc(options) then
		return
	end

	local clearEachPrediction = if typeof(options.ClearArc) == "boolean" then options.ClearArc else ARC_CLEAR_EACH_PREDICTION

	if clearEachPrediction then
		clearArcFolder()
	end

	local ragdolled = isCharacterRagdolled(character)
	local primaryColor = primaryPrediction.HitPart and ARC_HIT_COLOR or ARC_PRIMARY_COLOR

	drawSolidPath(primaryPrediction, primaryColor, options, "Primary")
	drawEndMarker(primaryPrediction)

	if not ragdolled then
		return
	end

	local drawExtra = if typeof(options.RagdollExtraPath) == "boolean" then options.RagdollExtraPath else RAGDOLL_DRAW_EXTRA_PATH

	if not drawExtra then
		return
	end

	local maxPaths = if isPositiveNumber(options.RagdollMaxVisualPaths) then options.RagdollMaxVisualPaths else RAGDOLL_MAX_VISUAL_PATHS
	maxPaths = math.clamp(math.floor(maxPaths), 1, 2)

	if maxPaths < 2 then
		return
	end

	local alternateVelocity = getRagdollAlternateVelocity(rootPart, options)
	local currentVelocity = rootPart.AssemblyLinearVelocity

	if (alternateVelocity - currentVelocity).Magnitude <= 0.5 then
		return
	end

	local alternatePrediction = buildPredictionFromState(
		character,
		rootPart,
		options,
		alternateVelocity,
		rootPart.AssemblyAngularVelocity
	)

	local secondaryColor = alternatePrediction.HitPart and ARC_HIT_COLOR or ARC_SECONDARY_COLOR

	drawSolidPath(alternatePrediction, secondaryColor, options, "RagdollAlt")
end

local function returnPrediction(prediction)
	return prediction.Trajectory, prediction.HitPart, prediction.HitResult, prediction
end

local function PredictPlayerLanding(playerOrCharacter, options)
	options = mergeOptions(options)

	local character = getCharacterFromPlayerOrCharacter(playerOrCharacter)
	local rootPart = getRootPart(character)

	if not rootPart or not rootPart:IsA("BasePart") then
		local emptyPrediction = {
			Trajectory = {},
			HitResult = nil,
			HitPart = nil,
			Reason = "No HumanoidRootPart/Torso found",
			DrawArc = options.DrawArc,
		}

		return returnPrediction(emptyPrediction)
	end

	local primaryPrediction = buildPredictionFromState(
		character,
		rootPart,
		options,
		rootPart.AssemblyLinearVelocity,
		rootPart.AssemblyAngularVelocity
	)

	primaryPrediction.DrawArc = options.DrawArc
	primaryPrediction.Ragdolled = isCharacterRagdolled(character)

	drawPredictionVisuals(character, rootPart, options, primaryPrediction)

	return returnPrediction(primaryPrediction)
end

return PredictPlayerLanding
