--------------------------------------------------------------------------
-- Trajectory Finder API (Optimized & Cleaned)
-- Returns PredictPlayerLanding(playerObjectOrCharacter, options)
--------------------------------------------------------------------------

local Workspace = game:GetService("Workspace")

local ARC_FOLDER_NAME = "__TrajectoryArcVisuals"

local DEFAULT_OPTIONS = {
	MaxTime    = 5,
	TimeStep   = 1 / 60,
	Gravity    = Workspace.Gravity,

	AirDensity       = 0.02,
	DragCoefficient  = 0.7,
	CrossSectionArea = 1.2,

	MagnusCoefficient     = 0.006,
	MaxMagnusAcceleration = 80,

	CastMode        = "Block",
	CastPadding     = 0.05,
	IgnoreWater     = true,
	IgnoreInstances = nil,

	Mass       = nil,
	CastSize   = nil,
	CastRadius = nil,

	DrawArc         = false,
	ClearArc        = true,
	ArcVisualStride = 1,
	ArcThickness    = 0.12,
	ArcTransparency = 0.08,

	RagdollExtraPath      = true,
	RagdollMaxVisualPaths = 2,
	RagdollSideVelocity   = 18,
	RagdollForwardBlend   = 0.35,
}

local COLOR_PRIMARY   = Color3.fromRGB(0,   255, 180)
local COLOR_SECONDARY = Color3.fromRGB(255, 190, 60)
local COLOR_HIT       = Color3.fromRGB(255, 70,  70)
local COLOR_END       = Color3.fromRGB(255, 0,   0)

-- Part Pool to prevent massive GC lag from constant Neon part destruction/creation
local activeVisualParts = {}
local partPool = {}

local function positive(v)
	return typeof(v) == "number" and v > 0
end

local function mergeOptions(options)
	local merged = table.clone(DEFAULT_OPTIONS)

	if typeof(options) == "table" then
		for k, v in pairs(options) do
			merged[k] = v
		end
	end

	if not positive(merged.MaxTime) then
		merged.MaxTime = DEFAULT_OPTIONS.MaxTime
	end

	if not positive(merged.TimeStep) then
		merged.TimeStep = DEFAULT_OPTIONS.TimeStep
	end

	merged.TimeStep = math.clamp(merged.TimeStep, 1 / 240, 1 / 10)

	if typeof(merged.Gravity) ~= "number" or merged.Gravity < 0 then
		merged.Gravity = Workspace.Gravity
	end

	if typeof(merged.IgnoreWater) ~= "boolean" then
		merged.IgnoreWater = DEFAULT_OPTIONS.IgnoreWater
	end

	return merged
end

local function getCharacter(value)
	if typeof(value) ~= "Instance" then return nil end
	if value:IsA("Player") then return value.Character end
	if value:IsA("Model") then return value end
	return nil
end

local function getRootPart(character)
	if not character then return nil end

	return character:FindFirstChild("HumanoidRootPart")
		or character:FindFirstChild("Torso")
		or character:FindFirstChild("UpperTorso")
end

local function getHumanoid(character)
	return character and character:FindFirstChildOfClass("Humanoid") or nil
end

local function isRagdollState(state)
	return state == Enum.HumanoidStateType.Physics
		or state == Enum.HumanoidStateType.Ragdoll
		or state == Enum.HumanoidStateType.FallingDown
end

local function isCharacterRagdolled(character)
	local humanoid = getHumanoid(character)
	return humanoid and isRagdollState(humanoid:GetState()) or false
end

local function getMass(rootPart, character, options)
	if positive(options.Mass) then return options.Mass end

	if rootPart and rootPart:IsA("BasePart") and rootPart.AssemblyMass > 0 then
		return rootPart.AssemblyMass
	end

	local total = 0

	if character then
		for _, d in ipairs(character:GetDescendants()) do
			if d:IsA("BasePart") then
				total += d:GetMass()
			end
		end
	end

	return total > 0 and total or 70
end

local function buildParams(character, options)
	local params = RaycastParams.new()
	params.FilterType  = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = options.IgnoreWater

	local ignore = {}

	if character then
		table.insert(ignore, character)
	end

	if typeof(options.IgnoreInstances) == "table" then
		for _, inst in ipairs(options.IgnoreInstances) do
			if typeof(inst) == "Instance" then
				table.insert(ignore, inst)
			end
		end
	end

	params.FilterDescendantsInstances = ignore
	return params
end

local function getCastInfo(rootPart, character, options)
	local mode = options.CastMode

	if mode ~= "Block" and mode ~= "Sphere" and mode ~= "Ray" then
		mode = "Block"
	end

	local rotation     = rootPart.CFrame.Rotation
	local centerOffset = Vector3.zero
	local size         = rootPart.Size

	if typeof(options.CastSize) == "Vector3" then
		size = options.CastSize
	elseif character then
		local ok, boxCFrame, boxSize = pcall(function()
			return character:GetBoundingBox()
		end)

		if ok and boxCFrame and boxSize then
			centerOffset = rootPart.CFrame:PointToObjectSpace(boxCFrame.Position)
			size         = boxSize
		end
	end

	local padding = positive(options.CastPadding) and options.CastPadding or 0

	size = Vector3.new(
		math.max(size.X - padding, 0.1),
		math.max(size.Y - padding, 0.1),
		math.max(size.Z - padding, 0.1)
	)

	local radius = positive(options.CastRadius) and options.CastRadius
		or math.max(size.X, size.Z) * 0.5

	return {
		Mode         = mode,
		Rotation     = rotation,
		CenterOffset = centerOffset,
		Size         = size,
		Radius       = math.max(radius, 0.1),
	}
end

local function getDragAcceleration(velocity, mass, options)
	local speed = velocity.Magnitude

	if speed <= 0.001 then return Vector3.zero end

	local airDensity       = options.AirDensity or 0
	local dragCoefficient  = options.DragCoefficient or 0
	local crossSectionArea = options.CrossSectionArea or 0

	if airDensity <= 0 or dragCoefficient <= 0 or crossSectionArea <= 0 then
		return Vector3.zero
	end

	local dragMagnitude = 0.5 * airDensity * dragCoefficient * crossSectionArea * speed * speed
	return -velocity.Unit * (dragMagnitude / mass)
end

local function getMagnusAcceleration(velocity, angularVelocity, options)
	if velocity.Magnitude <= 0.001 or angularVelocity.Magnitude <= 0.001 then
		return Vector3.zero
	end

	local coefficient = options.MagnusCoefficient or 0

	if coefficient <= 0 then return Vector3.zero end

	local magnus   = angularVelocity:Cross(velocity) * coefficient
	local maxAccel = positive(options.MaxMagnusAcceleration) and options.MaxMagnusAcceleration or 80

	if magnus.Magnitude > maxAccel then
		magnus = magnus.Unit * maxAccel
	end

	return magnus
end

local function getArcFolder()
	local folder = Workspace:FindFirstChild(ARC_FOLDER_NAME)

	if not folder then
		folder        = Instance.new("Folder")
		folder.Name   = ARC_FOLDER_NAME
		folder.Parent = Workspace
	end

	return folder
end

local function clearArc()
	-- Recycle and hide active segments instead of blowing them away.
	for _, part in ipairs(activeVisualParts) do
		part.CFrame = CFrame.new(0, 50000, 0)
		part.Transparency = 1
		table.insert(partPool, part)
	end
	table.clear(activeVisualParts)
end

local function getPooledPart()
	local part = table.remove(partPool)
	if not part or not part.Parent then
		part = Instance.new("Part")
		part.Anchored      = true
		part.CanCollide    = false
		part.CanTouch      = false
		part.CanQuery      = false
		part.CastShadow    = false
		part.Material      = Enum.Material.Neon
		part.TopSurface    = Enum.SurfaceType.Smooth
		part.BottomSurface = Enum.SurfaceType.Smooth
	end
	return part
end

local function cylinderBetween(a, b)
	local midpoint  = (a + b) * 0.5
	local direction = b - a

	if direction.Magnitude <= 0.001 then
		return CFrame.new(midpoint)
	end

	local up    = direction.Unit
	local right = up:Cross(Vector3.new(0, 0, 1))

	if right.Magnitude <= 0.001 then
		right = up:Cross(Vector3.new(1, 0, 0))
	end

	right = right.Unit
	local back = right:Cross(up).Unit

	return CFrame.fromMatrix(midpoint, right, up, back)
end

local function drawPath(prediction, color, options, prefix)
	if not prediction or typeof(prediction.Trajectory) ~= "table" then return end

	local trajectory = prediction.Trajectory
	if #trajectory <= 1 then return end

	local folder       = getArcFolder()
	local stride       = math.max(math.floor(positive(options.ArcVisualStride) and options.ArcVisualStride or 1), 1)
	local thickness    = positive(options.ArcThickness)    and options.ArcThickness    or 0.12
	local transparency = typeof(options.ArcTransparency) == "number" and options.ArcTransparency or 0.08

	for i = 1, #trajectory - 1, stride do
		local a = trajectory[i]
		local b = trajectory[math.min(i + stride, #trajectory)]

		if typeof(a) == "Vector3" and typeof(b) == "Vector3" then
			local distance = (b - a).Magnitude

			if distance > 0.001 then
				local segment = getPooledPart()
				segment.Name  = prefix .. "_Path"
				segment.Size  = Vector3.new(thickness, distance, thickness)
				segment.Color = color
				segment.Transparency = transparency
				segment.Shape  = Enum.PartType.Cylinder
				segment.CFrame = cylinderBetween(a, b)
				segment.Parent = folder

				table.insert(activeVisualParts, segment)
			end
		end
	end
end

local function drawEndMarker(prediction)
	if not prediction or typeof(prediction.Trajectory) ~= "table" or #prediction.Trajectory == 0 then
		return
	end

	local pos = prediction.LandPosition
		or prediction.RootPosition
		or prediction.Trajectory[#prediction.Trajectory]

	if typeof(pos) ~= "Vector3" then return end

	local marker = getPooledPart()
	marker.Name          = "EndMarker"
	marker.Size          = Vector3.new(0.85, 0.85, 0.85)
	marker.Color         = COLOR_END
	marker.Transparency  = 0.02
	marker.Shape         = Enum.PartType.Ball
	marker.CFrame        = CFrame.new(pos)
	marker.Parent        = getArcFolder()

	table.insert(activeVisualParts, marker)
end

local function buildPrediction(character, rootPart, options, initialVelocity, initialAngularVelocity)
	local mass            = getMass(rootPart, character, options)
	local position        = rootPart.Position
	local velocity        = initialVelocity        or rootPart.AssemblyLinearVelocity
	local angularVelocity = initialAngularVelocity or rootPart.AssemblyAngularVelocity
	local gravity         = Vector3.new(0, -options.Gravity, 0)
	local params          = buildParams(character, options)
	local castInfo        = getCastInfo(rootPart, character, options)

	-- Pre-allocate arrays utilizing step budgets to optimize Luau memory indexing.
	local maxSteps        = math.ceil(options.MaxTime / options.TimeStep)
	local trajectory      = table.create(maxSteps + 1)
	table.insert(trajectory, position)
	
	local elapsed    = 0

	-- Pre-resolve the spherecast/blockcast runtime options once outside our loop.
	local castFunc
	if castInfo.Mode == "Ray" then
		castFunc = function(pos, disp)
			return Workspace:Raycast(pos, disp, params)
		end
	elseif castInfo.Mode == "Sphere" then
		castFunc = function(pos, disp)
			return Workspace:Spherecast(pos, castInfo.Radius, disp, params)
		end
	else -- "Block" default
		local rotation = castInfo.Rotation
		local size = castInfo.Size
		local offset = castInfo.CenterOffset
		castFunc = function(pos, disp)
			local center = pos + rotation:VectorToWorldSpace(offset)
			return Workspace:Blockcast(CFrame.new(center) * rotation, size, disp, params)
		end
	end

	while elapsed < options.MaxTime do
		if not rootPart.Parent then
			break
		end

		local step         = math.min(options.TimeStep, options.MaxTime - elapsed)
		local acceleration = gravity
			+ getDragAcceleration(velocity, mass, options)
			+ getMagnusAcceleration(velocity, angularVelocity, options)

		local nextVelocity = velocity + acceleration * step
		local nextPosition = position + velocity * step + 0.5 * acceleration * step * step
		local displacement = nextPosition - position

		-- Direct cast execution without runtime pcall-wrapping inside simulation.
		local ok, hitResult = pcall(castFunc, position, displacement)
		if not ok then
			-- Fallback to standard raycast if hardware streaming or client constraints drop execution context
			hitResult = Workspace:Raycast(position, displacement, params)
		end

		if hitResult then
			local alpha          = math.clamp(
				hitResult.Distance / math.max(displacement.Magnitude, 0.001),
				0, 1
			)
			local hitRootPosition = position:Lerp(nextPosition, alpha)

			table.insert(trajectory, hitRootPosition)

			return {
				Trajectory   = trajectory,
				HitResult    = hitResult,
				HitPart      = hitResult.Instance,
				LandPosition = hitResult.Position,
				RootPosition = hitRootPosition,
				LandNormal   = hitResult.Normal,
				Time         = elapsed + step * alpha,
				Velocity     = velocity:Lerp(nextVelocity, alpha),
				CastMode     = castInfo.Mode,
				CastSize     = castInfo.Size,
				CastRadius   = castInfo.Radius,
				Reason       = "Hit",
			}
		end

		position  = nextPosition
		velocity  = nextVelocity
		elapsed  += step

		table.insert(trajectory, position)
	end

	return {
		Trajectory   = trajectory,
		HitResult    = nil,
		HitPart      = nil,
		LandPosition = position,
		RootPosition = position,
		Time         = options.MaxTime,
		Velocity     = velocity,
		CastMode     = castInfo.Mode,
		CastSize     = castInfo.Size,
		CastRadius   = castInfo.Radius,
		Reason       = not rootPart.Parent and "RootPart removed during simulation"
			or "No hit within MaxTime",
	}
end

local function horizontal(v)
	return Vector3.new(v.X, 0, v.Z)
end

local function getRagdollAlternateVelocity(rootPart, options)
	local velocity = rootPart.AssemblyLinearVelocity
	local h        = horizontal(velocity)
	local look     = horizontal(rootPart.CFrame.LookVector)

	local baseDirection

	if h.Magnitude > 0.001 then
		baseDirection = h.Unit
	elseif look.Magnitude > 0.001 then
		baseDirection = look.Unit
	else
		baseDirection = Vector3.new(1, 0, 0)
	end

	local side = Vector3.new(-baseDirection.Z, 0, baseDirection.X).Unit

	if rootPart.AssemblyAngularVelocity.Y < 0 then
		side = -side
	end

	local sideVelocity = positive(options.RagdollSideVelocity) and options.RagdollSideVelocity or 18
	local forwardBlend = typeof(options.RagdollForwardBlend) == "number"
		and math.clamp(options.RagdollForwardBlend, 0, 1) or 0.35

	local alternateHorizontal = h * forwardBlend + side * sideVelocity
	return Vector3.new(alternateHorizontal.X, velocity.Y, alternateHorizontal.Z)
end

local function drawPrediction(character, rootPart, options, prediction)
	if options.DrawArc ~= true then return end
	if options.ClearArc ~= false then clearArc() end

	drawPath(prediction, prediction.HitPart and COLOR_HIT or COLOR_PRIMARY, options, "Primary")
	drawEndMarker(prediction)

	if not isCharacterRagdolled(character) or options.RagdollExtraPath == false then
		return
	end

	local alternateVelocity = getRagdollAlternateVelocity(rootPart, options)

	if (alternateVelocity - rootPart.AssemblyLinearVelocity).Magnitude <= 0.5 then
		return
	end

	local alternatePrediction = buildPrediction(
		character, rootPart, options,
		alternateVelocity, rootPart.AssemblyAngularVelocity
	)

	drawPath(
		alternatePrediction,
		alternatePrediction.HitPart and COLOR_HIT or COLOR_SECONDARY,
		options,
		"RagdollAlt"
	)
end

local function returnPrediction(prediction)
	return prediction.Trajectory, prediction.HitPart, prediction.HitResult, prediction
end

local function PredictPlayerLanding(playerOrCharacter, options)
	options = mergeOptions(options)

	local character = getCharacter(playerOrCharacter)
	local rootPart  = getRootPart(character)

	if not rootPart or not rootPart:IsA("BasePart") or not rootPart.Parent then
		return returnPrediction({
			Trajectory   = {},
			HitResult    = nil,
			HitPart      = nil,
			LandPosition = nil,
			RootPosition = nil,
			Reason       = "No valid HumanoidRootPart/Torso found",
		})
	end

	local prediction = buildPrediction(
		character,
		rootPart,
		options,
		rootPart.AssemblyLinearVelocity,
		rootPart.AssemblyAngularVelocity
	)

	prediction.DrawArc   = options.DrawArc
	prediction.Ragdolled = isCharacterRagdolled(character)

	drawPrediction(character, rootPart, options, prediction)

	return returnPrediction(prediction)
end

return PredictPlayerLanding
